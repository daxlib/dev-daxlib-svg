table Cards
	lineageTag: af6f98fc-8b42-4bf7-be69-52bd1653a0dc

	measure Card =
			
			SWITCH(
			    SELECTEDVALUE( Cards[Compound] ),
			    "Compound.Bars", [Compound.Bars],
			    "Compound.Line", [Compound.Line],
			    "Compound.Area", [Compound.Area],
			    "Compound.Jitter", [Compound.Jitter],
			    "Compound.ProgressBar", [Compound.ProgressBar],
			    "Compound.Boxplot", [Compound.BoxPlot],
			    "Compound.Violin", [Compound.Violin],
			    "Compound.Heatmap", [Compound.Heatmap],
			    "Compound.Pill", [Compound.Pill],
			    "Element.Txt", [Txt],
			    "Element.Rect", [Rect],
			    "Element.Line", [Line],
			    "Element.Path", [Path],
			    "Element.Circle", [Circle],
			    "Element.Use", [Use],
			    "Defs.LinearGradient", [Linear Gradient],
			    "Defs.RadialGradient", [Radial Gradient],
			    "Defs.ClipPath", [Clip Path]
			)
		lineageTag: 197396a2-dde4-4eba-a67a-2aebc997dfaf
		dataCategory: ImageUrl

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Compound

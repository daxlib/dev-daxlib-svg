	column Order
		formatString: 0
		lineageTag: ab2add2d-0b72-46d9-b719-f8326b9c30fb
		summarizeBy: none
		isNameInferred
		sourceColumn: [Order]

		annotation SummarizationSetBy = User

	partition Cards = calculated

/// Create a gradient stop element
/// @param {string} offset – Stop position
/// @param {string} color – color value (hex or named color)
/// @param {string} opacity – Optional: opacity value
/// @returns {string} <stop> element
function 'DaxLib.SVG.Def.GradientStop' =
		(
			offset: STRING,
			color: STRING,
			opacity: STRING
		) =>
		
			"<stop offset='" & offset &
			"' stop-color='" & color & "'" &
			IF( NOT ISBLANK( opacity ), " stop-opacity='" & opacity & "'" ) &
			"/>"
	lineageTag: 6db1f6fd-472a-4525-b203-6713cdaf2978


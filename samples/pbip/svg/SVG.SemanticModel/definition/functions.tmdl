/// Renders a single proportional bar as an SVG data URI, suitable for tables or button slicers
/// @param {numeric} measureRefExpr – Measure expression for bar value
/// @param {numeric} maxValue – Optional: maximum value for scaling
/// @param {string} color – Optional bar color
/// @param {string} trackColor – Optional background track color
/// @param {int} width – Optional: SVG width, defaults to 120
/// @param {int} height – Optional: SVG height, defaults to 48
/// @returns {string} SVG data URI with a single proportional bar
function 'DaxLib.SVG.Viz.Bar' =
		(
			measureRefExpr: NUMERIC EXPR,
			maxValue: NUMERIC,
			color: STRING,
			trackColor: STRING,
			width: INT64,
			height: INT64
		) =>
		
			VAR _W = IF( ISBLANK( width ), 120, width )
			VAR _H = IF( ISBLANK( height ), 48, height )
			VAR _Color = IF( NOT ISBLANK( color ), color, DaxLib.SVG.Color.Theme( "Power BI", 1 ) )
			VAR _Marks =
				DaxLib.SVG.Compound.Bar(
					0, 0, _W, _H, 0, 0,
					measureRefExpr, maxValue, _Color, trackColor, 2, FALSE()
				)
		
			RETURN
				IF( NOT ISBLANK( _Marks ), DaxLib.SVG.SVG( "100%", "100%", "0 0 " & _W & " " & _H, _Marks, BLANK() ) )
	lineageTag: e7a1c6f4-daba-44c9-bf7e-987b7ccbf706


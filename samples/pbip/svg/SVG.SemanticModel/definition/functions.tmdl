/// Builds a shared axis/value data table for compound visuals
/// @param {anyref} axisRefColumn – Axis reference column evaluated in current filter context
/// @param {numeric} measureRefExpr – Measure expression evaluated per axis value
/// @param {string} axisMode – "Auto", "Numeric", or "Categorical"
/// @returns {table} Standardized table with @AxisValue, @AxisIndex, and @Value
function 'DaxLib.SVG.Data.AxisMeasure' =
		(
			axisRefColumn: ANYREF EXPR,
			measureRefExpr: NUMERIC EXPR,
			axisMode: STRING
		) =>
		
			VAR _AxisMode =
				IF(
					axisMode = "Numeric" || axisMode = "Categorical",
					axisMode,
					"Auto"
				)
		
			VAR _AxisSample = MAX( axisRefColumn )
			VAR _AxisIsNumeric = ISNUMBER( _AxisSample ) || ISDATETIME( _AxisSample )
			VAR _UseNumericAxis =
				IF(
					_AxisMode = "Numeric",
					TRUE(),
					IF( _AxisMode = "Categorical", FALSE(), _AxisIsNumeric )
				)
		
			VAR _WithValues =
				ADDCOLUMNS(
					VALUES( axisRefColumn ),
					"@AxisValue", axisRefColumn,
					"@Value", measureRefExpr
				)
		
			VAR _Indexed =
				ADDCOLUMNS(
					_WithValues,
					"@AxisIndex",
						IF(
							_UseNumericAxis,
							[@AxisValue],
							RANK( DENSE, CALCULATETABLE( VALUES( axisRefColumn ), ALLSELECTED() ) )
						)
				)
		
			RETURN
				TOPN(
					COUNTROWS( _Indexed ),
					_Indexed,
					[@AxisIndex], ASC,
					[@AxisValue], ASC
				)
	lineageTag: 773a204e-cd61-470b-bc56-ea553e76d3b0

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Computes min/max/baseline values from shaped scalar range inputs
/// @param {numeric} dataMin – Minimum value from source data
/// @param {numeric} dataMax – Maximum value from source data
/// @param {boolean} includeZero – Use zero baseline when range is fully positive
/// @returns {table} Single-row table with @Min, @Max, and @Baseline
function 'DaxLib.SVG.Data.Range' =
		(
			dataMin: NUMERIC VAL,
			dataMax: NUMERIC VAL,
			includeZero: BOOLEAN
		) =>
		
			VAR _IncludeZero = IF( ISBLANK( includeZero ), FALSE(), includeZero )
			VAR _Min = dataMin
			VAR _Max = dataMax
			VAR _Baseline = IF( _IncludeZero && _Min > 0, 0, _Min )
		
			RETURN
				ROW(
					"@Min", _Min,
					"@Max", _Max,
					"@Baseline", _Baseline
				)
	lineageTag: 99afc807-78ea-4b20-8640-ea43d5e07764

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Estimates the maximum Y-axis tick label width for layout reservation
/// @param {numeric} axisMin – Axis minimum value
/// @param {numeric} axisMax – Axis maximum value
/// @param {int} tickCount – Number of ticks to estimate
/// @param {int} axisFontSize – Axis font size
/// @param {decimal} labelWidthFactor – Font width factor (Segoe UI default: 0.56)
/// @param {boolean} axisIsDate – Whether the axis values represent dates
/// @returns {numeric} Estimated max label width in pixels
function 'DaxLib.SVG.Axes.MaxTickLabelWidth' =
		(
			axisMin: NUMERIC VAL,
			axisMax: NUMERIC VAL,
			tickCount: INT64,
			axisFontSize: INT64,
			labelWidthFactor: DOUBLE,
			axisIsDate: BOOLEAN
		) =>
		
			VAR _TickCount = IF( ISBLANK( tickCount ) || tickCount < 1, 1, tickCount )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
			VAR _LabelWidthFactor = IF( ISBLANK( labelWidthFactor ), 0.56, labelWidthFactor )
			VAR _AxisIsDate = IF( ISBLANK( axisIsDate ), FALSE(), axisIsDate )
			VAR _NumericSpan = ABS( axisMax - axisMin )
			VAR _NumericDecimals = IF( _NumericSpan >= 100, 0, IF( _NumericSpan >= 10, 1, 2 ) )
		
			VAR _TickBase =
				ADDCOLUMNS(
					GENERATESERIES( 0, _TickCount - 1, 1 ),
					"@TickValue",
						IF(
							_TickCount = 1,
							axisMin,
							axisMin + DIVIDE( [Value], _TickCount - 1, 0 ) * ( axisMax - axisMin )
						)
				)
		
			VAR _LabelTable =
				ADDCOLUMNS(
					_TickBase,
					"@Label",
						FORMAT(
							IF(
								_AxisIsDate,
								[@TickValue],
								ROUND( [@TickValue], _NumericDecimals )
							),
							IF( _AxisIsDate, "dd-mmm-yy", "General Number" )
						)
				)
		
			VAR _MeasuredLabelTable =
				ADDCOLUMNS(
					_LabelTable,
					"@EstimatedWidth", LEN( [@Label] ) * _AxisFontSize * _LabelWidthFactor
				)
		
			RETURN
				MAXX( _MeasuredLabelTable, [@EstimatedWidth] )
	lineageTag: ba3e1e2e-cedc-4b07-908c-4a8bae0fcd5d

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Calculates axis-aware plot area bounds
/// @param {numeric} x – Content x
/// @param {numeric} y – Content y
/// @param {numeric} width – Content width
/// @param {numeric} height – Content height
/// @param {boolean} showAxis – Whether axes are enabled
/// @param {int} axisFontSize – Axis font size
/// @param {numeric} maxTickLabelWidth – Estimated max y-label width
/// @returns {table} Single-row table with @PlotX, @PlotY, @PlotWidth, @PlotHeight
function 'DaxLib.SVG.Axes.Layout' =
		(
			x: NUMERIC VAL,
			y: NUMERIC VAL,
			width: NUMERIC VAL,
			height: NUMERIC VAL,
			showAxis: BOOLEAN,
			axisFontSize: INT64,
			maxTickLabelWidth: NUMERIC VAL
		) =>
		
			VAR _ShowAxis = IF( ISBLANK( showAxis ), FALSE(), showAxis )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
			VAR _TickLength = 3
			VAR _TickPadding = 4
			VAR _AxisLinePadding = 2
		
			VAR _ReservedXAxisHeight = IF( _ShowAxis, _AxisFontSize + _TickLength + _TickPadding + _AxisLinePadding, 0 )
			VAR _ReservedYAxisWidth = IF( _ShowAxis, maxTickLabelWidth + _TickLength + _TickPadding + _AxisLinePadding, 0 )
			VAR _ReservedTopPadding = IF( _ShowAxis, _AxisFontSize / 2, 0 )
		
			RETURN
				ROW(
					"@PlotX", x + _ReservedYAxisWidth,
					"@PlotY", y + _ReservedTopPadding,
					"@PlotWidth", MAX( 0, width - _ReservedYAxisWidth ),
					"@PlotHeight", MAX( 0, height - _ReservedXAxisHeight - _ReservedTopPadding )
				)
	lineageTag: a6e6ec0b-7c84-4c5b-a79f-4bc4d2a7a608

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__


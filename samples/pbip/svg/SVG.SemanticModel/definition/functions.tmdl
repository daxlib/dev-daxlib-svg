/// Renders a bullet chart as an SVG data URI showing actual vs target values with qualitative bands
/// @param {anyref} axisRefColumn – Axis reference column for global scaling across rows
/// @param {numeric} valueRefExpr – Actual value expression
/// @param {numeric} targetRefExpr – Target value expression
/// @param {numeric} badThreshold – Optional lower qualitative threshold
/// @param {numeric} goodThreshold – Optional upper qualitative threshold
/// @param {string} color – Optional value bar color
/// @param {int} width – Optional: SVG width, defaults to 120
/// @param {int} height – Optional: SVG height, defaults to 48
/// @returns {string} SVG data URI with embedded bullet chart
function 'DaxLib.SVG.Viz.Bullet' =
		(
			axisRefColumn: ANYREF EXPR,
			valueRefExpr: NUMERIC EXPR,
			targetRefExpr: NUMERIC EXPR,
			badThreshold: NUMERIC,
			goodThreshold: NUMERIC,
			color: STRING,
			width: INT64,
			height: INT64
		) =>
		
			VAR _W = IF( ISBLANK( width ), 120, width )
			VAR _H = IF( ISBLANK( height ), 48, height )
			VAR _Color = IF( NOT ISBLANK( color ), color, DaxLib.SVG.Color.Theme( "Power BI", 1 ) )
			VAR _Marks =
				DaxLib.SVG.Compound.Bullet(
					0, 0, _W, _H, 0, 0,
					axisRefColumn, valueRefExpr, targetRefExpr, badThreshold, goodThreshold, _Color, "#323130"
				)
		
			RETURN
				IF( NOT ISBLANK( _Marks ), DaxLib.SVG.SVG( "100%", "100%", "0 0 " & _W & " " & _H, _Marks, BLANK() ) )

/// Creates a Bullet compound SVG visual with qualitative bands, value bar, and target marker
/// Scales consistently across rows using axisRef to find the global maximum value
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – Horizontal padding percentage (0.0-1.0)
/// @param {decimal} paddingY – Vertical padding percentage (0.0-1.0)
/// @param {anyref} axisRef – Axis reference column for global scale across rows
/// @param {numeric} valueRef – Actual value expression
/// @param {numeric} targetRef – Target value expression
/// @param {numeric} badThreshold – Optional lower qualitative threshold
/// @param {numeric} goodThreshold – Optional upper qualitative threshold
/// @param {string} barColor – Optional value bar color
/// @param {string} targetColor – Optional target marker color
/// @returns {string} SVG bullet chart element
function 'DaxLib.SVG.Compound.Bullet' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			valueRef: NUMERIC EXPR,
			targetRef: NUMERIC EXPR,
			badThreshold: NUMERIC,
			goodThreshold: NUMERIC,
			barColor: STRING,
			targetColor: STRING
		) =>
		
			VAR _X = x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = height * (1 - IF(ISBLANK(paddingY), 0, paddingY))
		
			VAR _Value = valueRef
			VAR _Target = targetRef
		
			// Find global max across all axis members for consistent scaling
			VAR _GlobalMax =
				MAXX(
					VALUES( axisRef ),
					MAX( ABS( valueRef ), ABS( targetRef ) )
				)
		
			VAR _BadThreshold = IF( ISBLANK( badThreshold ), _GlobalMax * 0.6, badThreshold )
			VAR _GoodThreshold = IF( ISBLANK( goodThreshold ), _GlobalMax * 0.85, goodThreshold )
		
			VAR _DomainMin = 0
			VAR _DomainMax = MAX( _GlobalMax, MAX( _BadThreshold, _GoodThreshold ) )
		
			VAR _BarColor = IF( NOT ISBLANK( barColor ), barColor, "#0F6CBD" )
			VAR _TargetColor = IF( NOT ISBLANK( targetColor ), targetColor, "#323130" )
		
			// Band positions – full width like ProgressBar
			VAR _B1E = DaxLib.SVG.Scale.Normalize( MIN( _DomainMax, _BadThreshold ), _DomainMin, _DomainMax, _X, _X + _Width )
			VAR _B2E = DaxLib.SVG.Scale.Normalize( MIN( _DomainMax, _GoodThreshold ), _DomainMin, _DomainMax, _X, _X + _Width )
		
			// Bands fill full height (like ProgressBar track)
			VAR _Bands =
				DaxLib.SVG.Element.Rect(
					_X, _Y, _B1E - _X, _Height, 0, 0,
					DaxLib.SVG.Attr.Shapes( "#F3F2F1", 1, BLANK(), BLANK(), BLANK(), BLANK(), BLANK() ),
					BLANK()
				)
				& DaxLib.SVG.Element.Rect(
					_B1E, _Y, _B2E - _B1E, _Height, 0, 0,
					DaxLib.SVG.Attr.Shapes( "#E1DFDD", 1, BLANK(), BLANK(), BLANK(), BLANK(), BLANK() ),
					BLANK()
				)
				& DaxLib.SVG.Element.Rect(
					_B2E, _Y, _X + _Width - _B2E, _Height, 0, 0,
					DaxLib.SVG.Attr.Shapes( "#C8C6C4", 1, BLANK(), BLANK(), BLANK(), BLANK(), BLANK() ),
					BLANK()
				)
		
			// Value bar – centered vertically like Compound.Bar
			VAR _BarCross = _Y + _Height * 0.25
			VAR _BarCrossLen = _Height * 0.5
			VAR _ValueEnd = DaxLib.SVG.Scale.Normalize( ABS( _Value ), _DomainMin, _DomainMax, _X, _X + _Width )
		
			VAR _ValueBar =
				DaxLib.SVG.Element.Rect(
					_X, _BarCross, _ValueEnd - _X, _BarCrossLen, 1, 1,
					DaxLib.SVG.Attr.Shapes( _BarColor, 0.9, BLANK(), _BarColor, 1, BLANK(), BLANK() ),
					BLANK()
				)
		
			// Target marker
			VAR _TargetN = DaxLib.SVG.Scale.Normalize( _Target, _DomainMin, _DomainMax, _X, _X + _Width )
		
			VAR _TargetMarker =
				DaxLib.SVG.Element.Line(
					_TargetN, _Y + _Height * 0.1,
					_TargetN, _Y + _Height * 0.9,
					DaxLib.SVG.Attr.Shapes( BLANK(), BLANK(), BLANK(), _TargetColor, 2, BLANK(), BLANK() ),
					BLANK()
				)
		
			RETURN
				IF( NOT ISBLANK( _Value ) && _Width > 0 && _Height > 0, _Bands & _ValueBar & _TargetMarker )
	lineageTag: 0b0a42c4-e1ea-46eb-8882-4ebbaaf81d84

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__


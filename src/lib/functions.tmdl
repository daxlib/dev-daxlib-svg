/// Wraps content in SVG container for Power BI visualization
/// @param {string} width – width (pixels or percentage)
/// @param {string} height – height (pixels or percentage)
/// @param {string} viewbox – Optional: viewBox (e.g., "0 0 100 100")
/// @param {string} contents – To include one or more SVG elements (e.g., from DaxLib.SVG.Element functions)
/// @param {numeric} sortValue – Optional: sort value for ordering in tables
/// @returns {string} SVG string
function 'DaxLib.SVG.SVG' =
		(
			width : STRING,
			height : STRING, 
			viewbox : STRING,
			contents : STRING,
			sortValue : NUMERIC
		) =>

			"data:image/svg+xml;utf8," &
			"<svg " & 
			"width='" & width & "' height='" & height & "' " &
			IF( NOT ISBLANK( viewbox ), "viewBox='" & viewbox & "' " ) &
			"xmlns='http://www.w3.org/2000/svg'>" &
			IF( NOT ISBLANK( sortValue ), "<desc>" & FORMAT( sortValue, "000000000000" ) & "</desc>" ) &
			contents &
			"</svg>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a wrapping multi-pill SVG compound in a bounded canvas
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – Horizontal padding percentage (0.0-1.0)
/// @param {decimal} paddingY – Vertical padding percentage (0.0-1.0)
/// @param {anyref} axisRefColumn – Axis column used for ordering and default labels
/// @param {string} labelExpr – Label expression evaluated per axis row
/// @param {numeric} valueExpr – Numeric expression evaluated per axis row
/// @param {string} colorExpr – Color expression evaluated per axis row
/// @param {int} pillHeight – Height of each pill
/// @param {int} minPillWidth – Minimum pill width
/// @param {int} maxPillWidth – Maximum pill width
/// @param {int} gapX – Horizontal gap between pills
/// @param {int} gapY – Vertical gap between rows
/// @param {int} maxRowCount – Maximum number of rows
/// @param {string} overflowMode – "Clip" or "EllipsisPill"
/// @param {string} sortMode – "AxisAsc", "AxisDesc", "ValueDesc", "ValueAsc"
/// @returns {string} Concatenated SVG pill elements
function 'DaxLib.SVG.Compound.Pills' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRefColumn: ANYREF EXPR,
			labelExpr: STRING EXPR,
			valueExpr: NUMERIC EXPR,
			colorExpr: STRING EXPR,
			pillHeight: INT64,
			minPillWidth: INT64,
			maxPillWidth: INT64,
			gapX: INT64,
			gapY: INT64,
			maxRowCount: INT64,
			overflowMode: STRING,
			sortMode: STRING
		) =>

			VAR _X = x + ( width * ( IF( ISBLANK( paddingX ), 0, paddingX ) / 2 ) )
			VAR _Y = y + ( height * ( IF( ISBLANK( paddingY ), 0, paddingY ) / 2 ) )
			VAR _Width = width * ( 1 - IF( ISBLANK( paddingX ), 0, paddingX ) )
			VAR _Height = height * ( 1 - IF( ISBLANK( paddingY ), 0, paddingY ) )

			VAR _ContentX = _X
			VAR _ContentY = _Y
			VAR _ContentWidth = MAX( 0, _Width )
			VAR _ContentHeight = MAX( 0, _Height )

			VAR _PillHeight = IF( ISBLANK( pillHeight ), 18, MAX( 8, pillHeight ) )
			VAR _MinPillWidth = IF( ISBLANK( minPillWidth ), 42, MAX( 16, minPillWidth ) )
			VAR _MaxPillWidth = IF( ISBLANK( maxPillWidth ), 120, MAX( _MinPillWidth, maxPillWidth ) )
			VAR _GapX = IF( ISBLANK( gapX ), 6, MAX( 0, gapX ) )
			VAR _GapY = IF( ISBLANK( gapY ), 6, MAX( 0, gapY ) )
			VAR _MaxRows = IF( ISBLANK( maxRowCount ), 3, MAX( 1, maxRowCount ) )
			VAR _OverflowMode = IF( overflowMode = "EllipsisPill", "EllipsisPill", "Clip" )
			VAR _SortMode =
				IF(
					sortMode = "AxisDesc" || sortMode = "ValueDesc" || sortMode = "ValueAsc",
					sortMode,
					"AxisAsc"
				)

			VAR _AxisSample = MAX( axisRefColumn )
			VAR _AxisIsNumeric = ISNUMBER( _AxisSample )

			VAR _Base =
				ADDCOLUMNS(
					VALUES( axisRefColumn ),
					"@AxisValue", axisRefColumn,
					"@AxisIndex",
						IF(
							_AxisIsNumeric,
							axisRefColumn,
							RANK( DENSE, CALCULATETABLE( VALUES( axisRefColumn ), ALLSELECTED() ) )
						),
					"@Value", valueExpr
				)

			VAR _RowAttributes =
				ADDCOLUMNS(
					VALUES( axisRefColumn ),
					"@AxisValue", axisRefColumn,
					"@LabelRaw", labelExpr,
					"@RowColor", colorExpr
				)

			VAR _Joined = NATURALLEFTOUTERJOIN( _Base, _RowAttributes )

			VAR _Prepared =
				ADDCOLUMNS(
					_Joined,
					"@Label", IF( NOT ISBLANK( [@LabelRaw] ), [@LabelRaw], FORMAT( [@AxisValue], "General Number" ) ),
					"@PillColor", IF( NOT ISBLANK( [@RowColor] ), [@RowColor], "#E8F0FB" ),
					"@LabelColor", IF( NOT ISBLANK( [@RowColor] ), [@RowColor], "#0F6CBD" )
				)

			VAR _Measured =
				ADDCOLUMNS(
					_Prepared,
					"@EstimatedLabelWidth", LEN( [@Label] ) * 12 * 0.56,
					"@PillWidth", MIN( _MaxPillWidth, MAX( _MinPillWidth, LEN( [@Label] ) * 12 * 0.56 + 24 ) )
				)

			VAR _Sorted =
				SWITCH(
					_SortMode,
					"AxisDesc", TOPN( COUNTROWS( _Measured ), _Measured, [@AxisIndex], DESC, [@AxisValue], DESC ),
					"ValueDesc", TOPN( COUNTROWS( _Measured ), _Measured, [@Value], DESC, [@AxisIndex], ASC ),
					"ValueAsc", TOPN( COUNTROWS( _Measured ), _Measured, [@Value], ASC, [@AxisIndex], ASC ),
					TOPN( COUNTROWS( _Measured ), _Measured, [@AxisIndex], ASC, [@AxisValue], ASC )
				)

			VAR _Ordered =
				ADDCOLUMNS(
					_Sorted,
					"@Order",
						SWITCH(
							_SortMode,
							"AxisDesc", RANKX( _Sorted, [@AxisIndex], BLANK(), DESC, DENSE ),
							"ValueDesc", RANKX( _Sorted, [@Value] + DIVIDE( [@AxisIndex], 1000000000, 0 ), BLANK(), DESC, DENSE ),
							"ValueAsc", RANKX( _Sorted, [@Value] + DIVIDE( [@AxisIndex], 1000000000, 0 ), BLANK(), ASC, DENSE ),
							RANKX( _Sorted, [@AxisIndex], BLANK(), ASC, DENSE )
						)
				)

			VAR _AverageWidth = MAX( _MinPillWidth, AVERAGEX( _Ordered, [@PillWidth] ) )
			VAR _Columns = MAX( 1, INT( DIVIDE( _ContentWidth + _GapX, _AverageWidth + _GapX, 1 ) ) )
			VAR _CellWidth = DIVIDE( _ContentWidth - ( _GapX * ( _Columns - 1 ) ), _Columns, _ContentWidth )

			VAR _Positioned =
				ADDCOLUMNS(
					_Ordered,
					"@Row", INT( DIVIDE( [@Order] - 1, _Columns, 0 ) ) + 1,
					"@Col", MOD( [@Order] - 1, _Columns ) + 1,
					"@RenderWidth", MIN( [@PillWidth], _CellWidth ),
					"@RenderX", _ContentX + ( MOD( [@Order] - 1, _Columns ) * ( _CellWidth + _GapX ) ),
					"@RenderY", _ContentY + ( INT( DIVIDE( [@Order] - 1, _Columns, 0 ) ) * ( _PillHeight + _GapY ) )
				)

			VAR _Visible =
				FILTER(
					_Positioned,
					[@Row] <= _MaxRows
						&& [@RenderY] + _PillHeight <= _ContentY + _ContentHeight
				)

			VAR _HiddenCount = MAX( 0, COUNTROWS( _Ordered ) - COUNTROWS( _Visible ) )

			VAR _VisibleForRender =
				IF(
					_OverflowMode = "EllipsisPill" && _HiddenCount > 0,
					FILTER( _Visible, [@Order] < COUNTROWS( _Visible ) ),
					_Visible
				)

			VAR _RenderedPills =
				CONCATENATEX(
					_VisibleForRender,
					"<rect x='" & [@RenderX] & "' y='" & [@RenderY] & "' width='" & [@RenderWidth] & "' height='" & _PillHeight & "' rx='10' ry='10' fill='" & [@PillColor] & "' fill-opacity='0.2' stroke='" & [@PillColor] & "' stroke-width='1'/>"
					& "<text x='" & ( [@RenderX] + [@RenderWidth] * 0.5 ) & "' y='" & ( [@RenderY] + _PillHeight * 0.58 ) & "' text-anchor='middle' dominant-baseline='middle' font-family='Segoe UI' font-size='12' fill='" & [@LabelColor] & "'>" & [@Label] & "</text>",
					""
				)

			VAR _Ellipsis =
				IF(
					_OverflowMode = "EllipsisPill" && _HiddenCount > 0 && COUNTROWS( _Visible ) > 0,
					VAR _LastVisible = TOPN( 1, _Visible, [@Order], DESC )
					RETURN
						CONCATENATEX(
							_LastVisible,
							"<rect x='" & [@RenderX] & "' y='" & [@RenderY] & "' width='" & [@RenderWidth] & "' height='" & _PillHeight & "' rx='10' ry='10' fill='#E6E6E6' fill-opacity='0.7' stroke='#C8C8C8' stroke-width='1'/>"
							& "<text x='" & ( [@RenderX] + [@RenderWidth] * 0.5 ) & "' y='" & ( [@RenderY] + _PillHeight * 0.58 ) & "' text-anchor='middle' dominant-baseline='middle' font-family='Segoe UI' font-size='12' fill='#605E5C'>+" & _HiddenCount & "</text>",
							""
						)
				)

			RETURN
				IF( _ContentWidth > 0 && _ContentHeight > 0, _RenderedPills & _Ellipsis )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Map a value from one value scale to another
/// Used for scaling values to fit within SVG dimensions
/// @param {numeric} inputValue – The value to map
/// @param {numeric} fromMin – The minimum value of the original scale
/// @param {numeric} fromMax – The maximum value of the original scale
/// @param {numeric} toMin – The minimum value of the new scale
/// @param {numeric} toMax – The maximum value of the new scale
/// @returns {decimal} mapped value
function 'DaxLib.SVG.Scale.Normalize' =
		(
			inputValue: NUMERIC VAL,
			fromMin: NUMERIC VAL,
			fromMax: NUMERIC VAL,
			toMin: NUMERIC VAL,
			toMax: NUMERIC VAL
		) =>
			
			( ( inputValue - fromMin ) / ( fromMax - fromMin ) ) * ( toMax - toMin ) + toMin

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Builds a shared axis/value data table for compound visuals
/// @param {anyref} axisRefColumn – Axis reference column evaluated in current filter context
/// @param {numeric} measureRefExpr – Measure expression evaluated per axis value
/// @param {string} axisMode – "Auto", "Numeric", or "Categorical"
/// @returns {table} Standardized table with @AxisValue, @AxisIndex, and @Value
function 'DaxLib.SVG.Data.AxisMeasure' =
		(
			axisRefColumn: ANYREF EXPR,
			measureRefExpr: NUMERIC EXPR,
			axisMode: STRING
		) =>

			VAR _AxisMode =
				IF(
					axisMode = "Numeric" || axisMode = "Categorical",
					axisMode,
					"Auto"
				)

			VAR _AxisSample = MAX( axisRefColumn )
			VAR _AxisIsNumeric = ISNUMBER( _AxisSample )
			VAR _UseNumericAxis =
				IF(
					_AxisMode = "Numeric",
					TRUE(),
					IF( _AxisMode = "Categorical", FALSE(), _AxisIsNumeric )
				)

			VAR _WithValues =
				ADDCOLUMNS(
					VALUES( axisRefColumn ),
					"@AxisValue", axisRefColumn,
					"@Value", measureRefExpr
				)

			VAR _Indexed =
				ADDCOLUMNS(
					_WithValues,
					"@AxisIndex",
						IF(
							_UseNumericAxis,
							[@AxisValue],
							RANK( DENSE, CALCULATETABLE( VALUES( axisRefColumn ), ALLSELECTED() ) )
						)
				)

			RETURN
				TOPN(
					COUNTROWS( _Indexed ),
					_Indexed,
					[@AxisIndex], ASC,
					[@AxisValue], ASC
				)

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Computes min/max/baseline values from shaped scalar range inputs
/// @param {numeric} dataMin – Minimum value from source data
/// @param {numeric} dataMax – Maximum value from source data
/// @param {boolean} includeZero – Use zero baseline when range is fully positive
/// @returns {table} Single-row table with @Min, @Max, and @Baseline
function 'DaxLib.SVG.Data.Range' =
		(
			dataMin: NUMERIC VAL,
			dataMax: NUMERIC VAL,
			includeZero: BOOLEAN
		) =>

			VAR _IncludeZero = IF( ISBLANK( includeZero ), FALSE(), includeZero )
			VAR _Min = dataMin
			VAR _Max = dataMax
			VAR _Baseline = IF( _IncludeZero && _Min > 0, 0, _Min )

			RETURN
				ROW(
					"@Min", _Min,
					"@Max", _Max,
					"@Baseline", _Baseline
				)

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Estimates the maximum Y-axis tick label width for layout reservation
/// @param {numeric} axisMin – Axis minimum value
/// @param {numeric} axisMax – Axis maximum value
/// @param {int} tickCount – Number of ticks to estimate
/// @param {int} axisFontSize – Axis font size
/// @param {decimal} labelWidthFactor – Font width factor (Segoe UI default: 0.56)
/// @returns {numeric} Estimated max label width in pixels
function 'DaxLib.SVG.Axis.MaxTickLabelWidth' =
		(
			axisMin: NUMERIC VAL,
			axisMax: NUMERIC VAL,
			tickCount: INT64,
			axisFontSize: INT64,
			labelWidthFactor: DOUBLE
		) =>

			VAR _TickCount = IF( ISBLANK( tickCount ) || tickCount < 1, 1, tickCount )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
			VAR _LabelWidthFactor = IF( ISBLANK( labelWidthFactor ), 0.56, labelWidthFactor )

			VAR _LabelTable =
				ADDCOLUMNS(
					GENERATESERIES( 0, _TickCount - 1, 1 ),
					"@TickValue",
						IF(
							_TickCount = 1,
							axisMin,
							axisMin + DIVIDE( [Value], _TickCount - 1, 0 ) * ( axisMax - axisMin )
						),
					"@Label", FORMAT( [@TickValue], "General Number" ),
					"@EstimatedWidth", LEN( [@Label] ) * _AxisFontSize * _LabelWidthFactor
				)

			RETURN
				MAXX( _LabelTable, [@EstimatedWidth] )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Calculates axis-aware plot area bounds
/// @param {numeric} x – Content x
/// @param {numeric} y – Content y
/// @param {numeric} width – Content width
/// @param {numeric} height – Content height
/// @param {boolean} showAxis – Whether axes are enabled
/// @param {int} axisFontSize – Axis font size
/// @param {numeric} maxTickLabelWidth – Estimated max y-label width
/// @returns {table} Single-row table with @PlotX, @PlotY, @PlotWidth, @PlotHeight
function 'DaxLib.SVG.Axis.Layout' =
		(
			x: NUMERIC VAL,
			y: NUMERIC VAL,
			width: NUMERIC VAL,
			height: NUMERIC VAL,
			showAxis: BOOLEAN,
			axisFontSize: INT64,
			maxTickLabelWidth: NUMERIC VAL
		) =>

			VAR _ShowAxis = IF( ISBLANK( showAxis ), FALSE(), showAxis )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
			VAR _TickLength = 3
			VAR _TickPadding = 4
			VAR _AxisLinePadding = 2

			VAR _ReservedXAxisHeight = IF( _ShowAxis, _AxisFontSize + _TickLength + _TickPadding + _AxisLinePadding, 0 )
			VAR _ReservedYAxisWidth = IF( _ShowAxis, maxTickLabelWidth + _TickLength + _TickPadding + _AxisLinePadding, 0 )

			RETURN
				ROW(
					"@PlotX", x + _ReservedYAxisWidth,
					"@PlotY", y,
					"@PlotWidth", MAX( 0, width - _ReservedYAxisWidth ),
					"@PlotHeight", MAX( 0, height - _ReservedXAxisHeight )
				)

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Renders cartesian axis lines, ticks, and labels
/// @returns {string} Axis SVG string or blank when axes are disabled
function 'DaxLib.SVG.Axis.Render' =
		(
			plotX: NUMERIC VAL,
			plotY: NUMERIC VAL,
			plotWidth: NUMERIC VAL,
			plotHeight: NUMERIC VAL,
			xAxisMin: NUMERIC VAL,
			xAxisMax: NUMERIC VAL,
			yAxisMin: NUMERIC VAL,
			yAxisMax: NUMERIC VAL,
			showAxis: BOOLEAN,
			axisFontSize: INT64
		) =>

			VAR _ShowAxis = IF( ISBLANK( showAxis ), FALSE(), showAxis )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
			VAR _AxisFontFamily = "Segoe UI"
			VAR _AxisColor = "#605E5C"
			VAR _AxisLineStrokeWidth = 1
			VAR _TickLength = 3
			VAR _TickPadding = 4
			VAR _TickCountX = 5
			VAR _TickCountY = 4

			VAR _XTickTable =
				ADDCOLUMNS(
					GENERATESERIES( 0, _TickCountX - 1, 1 ),
					"@TickValue",
						IF(
							_TickCountX = 1,
							xAxisMin,
							xAxisMin + DIVIDE( [Value], _TickCountX - 1, 0 ) * ( xAxisMax - xAxisMin )
						),
					"@Pos",
						IF(
							xAxisMax = xAxisMin,
							plotX + plotWidth / 2,
							DaxLib.SVG.Scale.Normalize( [@TickValue], xAxisMin, xAxisMax, plotX, plotX + plotWidth )
						),
					"@Label", FORMAT( [@TickValue], "General Number" )
				)

			VAR _YTickTable =
				ADDCOLUMNS(
					GENERATESERIES( 0, _TickCountY - 1, 1 ),
					"@TickValue",
						IF(
							_TickCountY = 1,
							yAxisMin,
							yAxisMin + DIVIDE( [Value], _TickCountY - 1, 0 ) * ( yAxisMax - yAxisMin )
						),
					"@Pos",
						IF(
							yAxisMax = yAxisMin,
							plotY + plotHeight / 2,
							DaxLib.SVG.Scale.Normalize( [@TickValue], yAxisMin, yAxisMax, plotY + plotHeight, plotY )
						),
					"@Label", FORMAT( [@TickValue], "General Number" )
				)

			VAR _XAxisLine =
				DaxLib.SVG.Element.Line(
					plotX,
					plotY + plotHeight,
					plotX + plotWidth,
					plotY + plotHeight,
					DaxLib.SVG.Attr.Shapes( BLANK(), BLANK(), BLANK(), _AxisColor, _AxisLineStrokeWidth, BLANK(), BLANK() ),
					BLANK()
				)

			VAR _YAxisLine =
				DaxLib.SVG.Element.Line(
					plotX,
					plotY,
					plotX,
					plotY + plotHeight,
					DaxLib.SVG.Attr.Shapes( BLANK(), BLANK(), BLANK(), _AxisColor, _AxisLineStrokeWidth, BLANK(), BLANK() ),
					BLANK()
				)

			VAR _XTicks =
				CONCATENATEX(
					_XTickTable,
					DaxLib.SVG.Element.Line(
						[@Pos],
						plotY + plotHeight,
						[@Pos],
						plotY + plotHeight + _TickLength,
						DaxLib.SVG.Attr.Shapes( BLANK(), BLANK(), BLANK(), _AxisColor, 1, BLANK(), BLANK() ),
						BLANK()
					)
					&
					DaxLib.SVG.Element.Txt(
						[@Pos],
						plotY + plotHeight + _TickLength + _TickPadding,
						[@Label],
						BLANK(),
						BLANK(),
						DaxLib.SVG.Attr.Shapes( _AxisColor, BLANK(), BLANK(), BLANK(), BLANK(), BLANK(), BLANK() )
						& DaxLib.SVG.Attr.Txt( _AxisFontFamily, _AxisFontSize, BLANK(), BLANK(), "middle", "hanging", BLANK(), BLANK(), BLANK() ),
						BLANK()
					),
					""
				)

			VAR _YTicks =
				CONCATENATEX(
					_YTickTable,
					DaxLib.SVG.Element.Line(
						plotX - _TickLength,
						[@Pos],
						plotX,
						[@Pos],
						DaxLib.SVG.Attr.Shapes( BLANK(), BLANK(), BLANK(), _AxisColor, 1, BLANK(), BLANK() ),
						BLANK()
					)
					&
					DaxLib.SVG.Element.Txt(
						plotX - _TickLength - _TickPadding,
						[@Pos],
						[@Label],
						BLANK(),
						BLANK(),
						DaxLib.SVG.Attr.Shapes( _AxisColor, BLANK(), BLANK(), BLANK(), BLANK(), BLANK(), BLANK() )
						& DaxLib.SVG.Attr.Txt( _AxisFontFamily, _AxisFontSize, BLANK(), BLANK(), "end", "middle", BLANK(), BLANK(), BLANK() ),
						BLANK()
					),
					""
				)

			RETURN
				IF( _ShowAxis, _XAxisLine & _YAxisLine & _XTicks & _YTicks )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Maps axis/value data to plot coordinates honoring orientation
/// @returns {table} Single-row table with @X and @Y
function 'DaxLib.SVG.Axis.Point' =
		(
			orientation: STRING,
			axisIndex: NUMERIC VAL,
			measureValue: NUMERIC VAL,
			xMin: NUMERIC VAL,
			xMax: NUMERIC VAL,
			yMin: NUMERIC VAL,
			yMax: NUMERIC VAL,
			plotX: NUMERIC VAL,
			plotY: NUMERIC VAL,
			plotWidth: NUMERIC VAL,
			plotHeight: NUMERIC VAL
		) =>

			VAR _Orientation = IF( orientation = "Horizontal", "Horizontal", "Vertical" )

			VAR _AxisX = IF( xMax = xMin, plotX, DaxLib.SVG.Scale.Normalize( axisIndex, xMin, xMax, plotX, plotX + plotWidth ) )
			VAR _AxisY = IF( xMax = xMin, plotY + plotHeight, DaxLib.SVG.Scale.Normalize( axisIndex, xMin, xMax, plotY + plotHeight, plotY ) )

			VAR _ValueX = IF( yMax = yMin, plotX, DaxLib.SVG.Scale.Normalize( measureValue, yMin, yMax, plotX, plotX + plotWidth ) )
			VAR _ValueY = IF( yMax = yMin, plotY + plotHeight, DaxLib.SVG.Scale.Normalize( measureValue, yMin, yMax, plotY + plotHeight, plotY ) )

			RETURN
				ROW(
					"@X", IF( _Orientation = "Horizontal", _ValueX, _AxisX ),
					"@Y", IF( _Orientation = "Horizontal", _AxisY, _ValueY )
				)

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Maps the numeric baseline to plot coordinates honoring orientation
/// @returns {table} Single-row table with @BaseX and @BaseY
function 'DaxLib.SVG.Axis.Baseline' =
		(
			orientation: STRING,
			yMin: NUMERIC VAL,
			yMax: NUMERIC VAL,
			plotX: NUMERIC VAL,
			plotY: NUMERIC VAL,
			plotWidth: NUMERIC VAL,
			plotHeight: NUMERIC VAL
		) =>

			VAR _Orientation = IF( orientation = "Horizontal", "Horizontal", "Vertical" )
			VAR _BaseX = IF( yMax = yMin, plotX, DaxLib.SVG.Scale.Normalize( yMin, yMin, yMax, plotX, plotX + plotWidth ) )
			VAR _BaseY = IF( yMax = yMin, plotY + plotHeight, DaxLib.SVG.Scale.Normalize( yMin, yMin, yMax, plotY + plotHeight, plotY ) )

			RETURN
				ROW(
					"@BaseX", IF( _Orientation = "Horizontal", _BaseX, plotX ),
					"@BaseY", IF( _Orientation = "Horizontal", plotY, _BaseY )
				)

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Generates a STRING of common shape attributes that can be passed to DaxLib.SVG.Element.* or DaxLib.SVG.Def.* functions
/// @param {string} fill – Fill color or gradient reference
/// @param {decimal} fillOpacity – Fill opacity (0-1)
/// @param {string} fillRule – Fill rule ("nonzero" or "evenodd")
/// @param {string} stroke – Stroke color
/// @param {int} strokeWidth – Stroke width
/// @param {decimal} strokeOpacity – Stroke opacity (0-1)
/// @param {decimal} opacity – Overall opacity (0-1)
/// @returns {string} An attribute string that can be used directly in SVG elements
function 'DaxLib.SVG.Attr.Shapes' = 
		(
			fill: STRING,
			fillOpacity: DOUBLE,
			fillRule: STRING,
			stroke: STRING,
			strokeWidth: INT64,
			strokeOpacity: DOUBLE,
			opacity: DOUBLE
		) =>

			IF( NOT ISBLANK( fill ),          "fill='" & fill & "' ") &
			IF( NOT ISBLANK( fillOpacity ),   "fill-opacity='" & fillOpacity & "' ") &
			IF( NOT ISBLANK( fillRule ),      "fill-rule='" & fillRule & "' ") &
			IF( NOT ISBLANK( stroke ),        "stroke='" & stroke & "' ") &
			IF( NOT ISBLANK( strokeWidth ),   "stroke-width='" & strokeWidth & "' ") &
			IF( NOT ISBLANK( strokeOpacity ), "stroke-opacity='" & strokeOpacity & "' ") &
			IF( NOT ISBLANK( opacity ),       "opacity='" & opacity & "' ")

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Text-specific attributes
/// @param {string} fontFamily – Font family for text
/// @param {int} fontSize – Font size for text
/// @param {string} fontWeight – Weight ("normal", "bold", "lighter", "100-900")
/// @param {string} fontStyle – Style ("normal", "italic", "oblique")
/// @param {string} textAnchor – Anchor ("start", "middle", "end")
/// @param {string} baseline – Dominant baseline
/// @param {string} textDecoration – Decoration ("none", "underline", "overline", "line-through")
/// @param {string} letterSpacing – Space between letters
/// @param {string} wordSpacing – Space between words
/// @returns {string} An attribute string that can be used directly in SVG text elements
function 'DaxLib.SVG.Attr.Txt' = 
		(
			fontFamily: STRING,
			fontSize: INT64,
			fontWeight: STRING,
			fontStyle: STRING,
			textAnchor: STRING,
			baseline: STRING,
			textDecoration: STRING,
			letterSpacing: STRING,
			wordSpacing: STRING
		) =>

			IF( NOT ISBLANK( fontFamily ),     "font-family='" & fontFamily & "' ") &
			IF( NOT ISBLANK( fontSize ),       "font-size='" & fontSize & "' ") &
			IF( NOT ISBLANK( fontWeight ),     "font-weight='" & fontWeight & "' ") &
			IF( NOT ISBLANK( fontStyle ),      "font-style='" & fontStyle & "' ") &
			IF( NOT ISBLANK( textAnchor ),     "text-anchor='" & textAnchor & "' ") &
			IF( NOT ISBLANK( baseline ),       "dominant-baseline='" & baseline & "' ") &
			IF( NOT ISBLANK( textDecoration ), "text-decoration='" & textDecoration & "' ") &
			IF( NOT ISBLANK( letterSpacing ),  "letter-spacing='" & letterSpacing & "' ") &
			IF( NOT ISBLANK( wordSpacing ),    "word-spacing='" & wordSpacing & "' ")

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Comprehensive stroke attributes function
/// @param {string} stroke – Stroke color (e.g., "#FF0000", "red")
/// @param {int} strokeWidth – Stroke width
/// @param {decimal} strokeOpacity – Stroke opacity (0-1)
/// @param {string} strokeDasharray – Stroke dasharray pattern (e.g., "5,5" for dashed)
/// @param {string} strokeDashoffset – Stroke dashoffset
/// @param {string} strokeLinecap – Stroke linecap ("butt", "round", "square")
/// @param {string} strokeLinejoin – Stroke linejoin ("miter", "round", "bevel")
/// @param {string} strokeMiterlimit – Miter limit for stroke joins
/// @param {string} markerStart – Marker for start of line (e.g., 'url(#arrowStart)')
/// @param {string} markerMid – Marker for middle points of line
/// @param {string} markerEnd – Marker for end of line (e.g., 'url(#arrowEnd)')
/// @returns {string} An attribute string that can be used directly in SVG elements
function 'DaxLib.SVG.Attr.Stroke' = 
		(
			stroke: STRING,
			strokeWidth: INT64,
			strokeOpacity: DOUBLE,
			strokeDasharray: STRING,
			strokeDashoffset: STRING,
			strokeLinecap: STRING,
			strokeLinejoin: STRING,
			strokeMiterlimit: STRING,
			markerStart: STRING,
			markerMid: STRING,
			markerEnd: STRING
		) =>
			VAR _Stroke =           IF(NOT ISBLANK(stroke),           "stroke='" & stroke & "' ")
			VAR _StrokeWidth =      IF(NOT ISBLANK(strokeWidth),      "stroke-width='" & strokeWidth & "' ")
			VAR _StrokeOpacity =    IF(NOT ISBLANK(strokeOpacity),    "stroke-opacity='" & strokeOpacity & "' ")
			VAR _StrokeDasharray =  IF(NOT ISBLANK(strokeDasharray),  "stroke-dasharray='" & strokeDasharray & "' ")
			VAR _StrokeDashoffset = IF(NOT ISBLANK(strokeDashoffset), "stroke-dashoffset='" & strokeDashoffset & "' ")
			VAR _StrokeLinecap =    IF(NOT ISBLANK(strokeLinecap),    "stroke-linecap='" & strokeLinecap & "' ")
			VAR _StrokeLinejoin =   IF(NOT ISBLANK(strokeLinejoin),   "stroke-linejoin='" & strokeLinejoin & "' ")
			VAR _StrokeMiterlimit = IF(NOT ISBLANK(strokeMiterlimit), "stroke-miterlimit='" & strokeMiterlimit & "' ")
			VAR _MarkerStart =      IF(NOT ISBLANK(markerStart),      "marker-start='" & markerStart & "' ")
			VAR _MarkerMid =        IF(NOT ISBLANK(markerMid),        "marker-mid='" & markerMid & "' ")
			VAR _MarkerEnd =        IF(NOT ISBLANK(markerEnd),        "marker-end='" & markerEnd & "' ")
			
			RETURN
				_Stroke &
				_StrokeWidth &
				_StrokeOpacity &
				_StrokeDasharray &
				_StrokeDashoffset &
				_StrokeLinecap &
				_StrokeLinejoin &
				_StrokeMiterlimit &
				_MarkerStart &
				_MarkerMid &
				_MarkerEnd

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Generates transform string for SVG elements
/// @param {string} translate – Translation coordinates (e.g., "10,20")
/// @param {string} rotate – Rotation with optional center point (e.g., "45" or "45 50 50")
/// @param {string} scale – Scale factors (e.g., "2" or "2,1.5")
/// @param {string} skewX – Horizontal skew angle in degrees
/// @param {string} skewY – Vertical skew angle in degrees
/// @returns {string} A transform attribute value that can be used with the transform attribute of SVG elements.
function 'DaxLib.SVG.Transforms' = 
		(
			translate: STRING,
			rotate: STRING,
			scale: STRING,
			skewX: STRING,
			skewY: STRING
		) =>

			IF(NOT ISBLANK(translate), "translate(" & translate & ") ") &
			IF(NOT ISBLANK(rotate), "rotate(" & rotate & ") ") &
			IF(NOT ISBLANK(scale), "scale(" & scale & ") ") &
			IF(NOT ISBLANK(skewX), "skewX(" & skewX & ") ") &
			IF(NOT ISBLANK(skewY), "skewY(" & skewY & ") ") 

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a <defs> element from one or more DaxLib.SVG.Def.* elements
/// @param {string} defs – Concatenated list of def elements to include in a <defs> block
/// @returns {string} <defs> element
function 'DaxLib.SVG.Element.Defs' = 
		(
			defs: STRING    // concatenated list of elements to include in a <defs> block
		) =>

			"<defs>" &
			defs &  
			"</defs>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a gradient stop element
/// @param {string} offset – Stop position
/// @param {string} color – color value (hex or named color)
/// @param {string} opacity – Optional: opacity value
/// @returns {string} <stop> element
function 'DaxLib.SVG.Def.GradientStop' = 
		(
			offset: STRING,
			color: STRING,
			opacity: STRING
		) =>

			"<stop offset='" & offset & 
			"' stop-color='" & color & "'" &
			IF( NOT ISBLANK( opacity ), " stop-opacity='" & opacity & "'" ) &
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a linear gradient definition
/// @param {string} defId – The unique identifier for the gradient
/// @param {string} stops – Concatenated list of one or more DaxLib.SVG.Def.GradientStop elements
/// @param {string} x1 – Optional: Start X position
/// @param {string} y1 – Optional: Start Y position
/// @param {string} x2 – Optional: End X position
/// @param {string} y2 – Optional: End Y position
/// @returns {string} <linearGradient> definition
function 'DaxLib.SVG.Def.LinearGradient' = 
		(
			defId: STRING,
			stops: STRING,
			x1: STRING,
			y1: STRING,
			x2: STRING,
			y2: STRING
		) =>
			
			"<linearGradient" & 
			" id='" & defId & "'" &
			IF( NOT ISBLANK( x1 ), " x1='" & x1 & "'" ) &
			IF( NOT ISBLANK( y1 ), " y1='" & y1 & "'" ) &
			IF( NOT ISBLANK( x2 ), " x2='" & x2 & "'" ) &
			IF( NOT ISBLANK( y2 ), " y2='" & y2 & "'" ) &
			">" &
			stops &
			"</linearGradient>"
	
	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a radial gradient definition
/// @param {string} defId – The unique identifier for the gradient
/// @param {string} stops – Concatenated list of one or more DaxLib.SVG.Def.GradientStop elements
/// @param {string} cx – Optional: Center X position
/// @param {string} cy – Optional: Center Y position
/// @param {string} r – Optional: Radius
/// @param {string} fx – Optional: Focus X position
/// @param {string} fy – Optional: Focus Y position
/// @param {string} fr – Optional: Focus radius
/// @returns {string} <radialGradient> definition
function 'DaxLib.SVG.Def.RadialGradient' = 
		(
			defId: STRING,
			stops: STRING,
			cx: STRING,
			cy: STRING,
			r: STRING,
			fx: STRING,
			fy: STRING,
			fr: STRING
		) =>

			"<radialGradient" & 
			" id='" & defId & "'" &
			IF( NOT ISBLANK( cx ), " cx='" & cx & "'" ) &
			IF( NOT ISBLANK( cy ), " cy='" & cy & "'" ) &
			IF( NOT ISBLANK( r ),  " r='" & r & "'" ) &
			IF( NOT ISBLANK( fx ), " fx='" & fx & "'" ) &
			IF( NOT ISBLANK( fy ), " fy='" & fy & "'" ) &
			IF( NOT ISBLANK( fr ), " fr='" & fr & "'" ) &
			">" &
			stops &
			"</radialGradient>"
	
	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a clipping mask definition
/// @param {string} defId – The unique identifier for the clip path. (Example: "cut-top", "mask-circle")
/// @param {string} contents – The SVG element(s) that make up the clipping path (typically a single shape)
/// @returns {string} <clipPath> definition
function 'DaxLib.SVG.Def.ClipPath' =
		(
			defId : STRING,
			contents: STRING
		) =>
			
			"<clipPath id='" & defId & "'>" &
			contents &
			"</clipPath>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a reusable circle definition
/// @param {string} defId – The unique identifier for the circle
/// @param {string} cx – X center coordinate
/// @param {string} cy – Y center coordinate
/// @param {string} r – Radius
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "fill='none' stroke='blue'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <circle> definition
function 'DaxLib.SVG.Def.Circle' = 
		(
			defId: STRING,
			cx: STRING,
			cy: STRING,  
			r: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<circle id='" & defId & "'" &
			" cx='" & cx & "'" &
			" cy='" & cy & "'" &
			" r='" & r & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) &
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a reusable rectangle definition
/// @param {string} defId – The unique identifier for the rectangle
/// @param {string} width – The width of the rectangle (pixels or percentage)
/// @param {string} height – The height of the rectangle (pixels or percentage)
/// @param {string} rx – Optional: x radius for rounded corners
/// @param {string} ry – Optional: y radius for rounded corners
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "fill='none' stroke='blue'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <rect> definition
function 'DaxLib.SVG.Def.Rect' = 
		(
			defId: STRING,
			width: STRING,
			height: STRING,
			rx: STRING,
			ry: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<rect id='" & defId & "'" &
			" width='" & width & "'" &
			" height='" & height & "'" &
			IF(NOT ISBLANK( rx ), " rx='" & rx & "'" ) & 
			IF(NOT ISBLANK( ry ), " ry='" & ry & "'" ) &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) &
			"/>"	

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a reusable line definition
/// @param {string} defId – The unique identifier for the line
/// @param {string} x1 – The x position of the start point
/// @param {string} y1 – The y position of the start point
/// @param {string} x2 – The x position of the end point
/// @param {string} y2 – The y position of the end point
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "stroke-width='2' stroke='blue'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <line> definition
function 'DaxLib.SVG.Def.Line' = 
		(
			defId: STRING,
			x1: STRING,
			y1: STRING,
			x2: STRING,
			y2: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<line id='" & defId & "'" &
			" x1='" & x1 & "'" &
			" y1='" & y1 & "'" &
			" x2='" & x2 & "'" &
			" y2='" & y2 & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) &
			"/>"
				
	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a reusable path definition
/// @param {string} defId – The unique identifier for the path
/// @param {string} d – The path data string (e.g., "M10 10 L90 90")
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "fill='none' stroke='blue'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <path> definition
function 'DaxLib.SVG.Def.Paths' =
		(
			defId: STRING,
			d: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<path id='" & defId & "'" &
			" d='" & d & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) &
			"/>"
				
	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Reference a previously defined SVG element with optional positioning and styling
/// This function is used to reuse elements that have been defined using DaxLib.SVG.Def.* functions
/// (e.g., DaxLib.SVG.Def.Circle, DaxLib.SVG.Def.Rect, DaxLib.SVG.Def.Paths, etc.). Instead of duplicating element definitions,
/// use the appropriate DaxLib.SVG.Def.* function once and then reference it multiple times with DaxLib.SVG.Element.UseDef.
/// @param {string} defId – The identifier of the defined element to use
/// @param {string} x – X position where the element should be placed
/// @param {string} y – Y position where the element should be placed
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <use> element
function 'DaxLib.SVG.Element.UseDef' = 
		(
			defId: STRING,
			x: STRING,
			y: STRING,
			transforms: STRING
		) =>

			"<use" &
			" href='#" & defId & "'" &
			IF( NOT ISBLANK( x ), " x='" & x & "'" ) &
			IF( NOT ISBLANK( y ), " y='" & y & "'" ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Generates SVG group element
/// Transformations applied to the <g> element are performed on its child elements, and its attributes are inherited by its children. It can also group multiple elements to be referenced later with the <use> element.
/// @param {string} contents – Content to group (recommend including all content in a single _SvgGroup variable defined upstream)
/// @param {string} opacity – Optional: Opacity for entire group (0-1, optional)
/// @param {string} transforms – Optional: Transform (e.g., "translate(50,50) rotate(45)") (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <g> element
function 'DaxLib.SVG.Element.Group' =
		(
			contents : STRING,
			opacity : STRING,
			transforms : STRING
		) =>

			"<g" &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) &
			IF( NOT ISBLANK( opacity ), " opacity='" & opacity & "'" ) &
			">" & contents & "</g>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Generates a circle SVG element
/// @param {string} cx – The x position of the center
/// @param {string} cy – The y position of the center
/// @param {string} r – The radius
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "fill='red' stroke-width='2'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <circle> element
function 'DaxLib.SVG.Element.Circle' = 
		(
			cx: STRING,
			cy: STRING,
			r: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<circle" &
			" cx='" & cx & "'" &
			" cy='" & cy & "'" &
			" r='" & r & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Generates a rectangle SVG element
/// @param {string} x – The x position
/// @param {string} y – The y position
/// @param {string} width – The width (pixels or percentage)
/// @param {string} height – The height (pixels or percentage)
/// @param {string} rx – Optional: x radius for rounded corners
/// @param {string} ry – Optional: y radius for rounded corners
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "fill='red' stroke-width='2'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <rect> element
function 'DaxLib.SVG.Element.Rect' =
		(
			x: STRING,
			y: STRING,
			width: STRING,
			height: STRING,
			rx: STRING,
			ry: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<rect" &
			" x='" & x & "'" &
			" y='" & y & "'" &
			" width='" & width & "'" &
			" height='" & height & "'" &
			IF( NOT ISBLANK( rx ), " rx='" & rx & "'" ) &
			IF( NOT ISBLANK( ry ), " ry='" & ry & "'" ) &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Generates SVG line element
/// @param {string} x1 – Starting X position (left edge is 0)
/// @param {string} y1 – Starting Y position (top edge is 0)
/// @param {string} x2 – Ending X position (left edge is 0)
/// @param {string} y2 – Ending Y position (top edge is 0)
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "stroke-dasharray='5,5' marker-end='url(#arrow)'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <line> element
function 'DaxLib.SVG.Element.Line' =
		(
			x1: STRING,
			y1: STRING,
			x2: STRING,
			y2: STRING,
			attributes: STRING,
			transforms: STRING
		) =>  
			
			"<line" &
			" x1='" & x1 & "'" &
			" y1='" & y1 & "'" &
			" x2='" & x2 & "'" &
			" y2='" & y2 & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create an SVG path element	
/// @param {string} d – The path data string (e.g., "M10 10 L90 90")
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "pathLength='100' fill-rule='evenodd'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <path> element
function 'DaxLib.SVG.Element.Paths' =
		(
			d: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<path d='" & d & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Generates an ellipse SVG element
/// @param {string} cx – The x position of the center
/// @param {string} cy – The y position of the center
/// @param {string} rx – The x radius
/// @param {string} ry – The y radius
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "fill='none' stroke='blue'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <ellipse> element
function 'DaxLib.SVG.Element.Ellipse' = 
		(
			cx: STRING,
			cy: STRING,
			rx: STRING,
			ry: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<ellipse" &
			" cx='" & cx & "'" &
			" cy='" & cy & "'" &
			" rx='" & rx & "'" &
			" ry='" & ry & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a polygon (closed shape)
/// @param {string} points – Space-separated x,y coordinate pairs (e.g., "0,10 20,30 40,15")
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "fill-rule='nonzero' vector-effect='non-scaling-stroke'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <polygon> element
function 'DaxLib.SVG.Element.Polygon' =
		(
			points: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<polygon" &
			" points='" & points & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a polyline (connected points)
/// @param {string} points – Space-separated x,y coordinate pairs (e.g., "0,10 20,30 40,15")
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "marker-start='url(#dot)' vector-effect='non-scaling-stroke'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: transformation to apply (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <polyline> element
function 'DaxLib.SVG.Element.Polyline' =
		(
			points: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<polyline" &
			" points='" & points & "'" &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) & 
			"/>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a text SVG element
/// @param {string} x – The x position of the text
/// @param {string} y – The y position of the text
/// @param {string} txt – The text content
/// @param {string} dx – Optional: x offset from position
/// @param {string} dy – Optional: y offset from position
/// @param {string} attributes – Optional: Direct SVG attributes to apply (e.g., "text-anchor='middle' dominant-baseline='middle'"), can generate with DaxLib.SVG.Attr.* or manually
/// @param {string} transforms – Optional: additional transforms (e.g. "scale(1.2) translate(10,10)") (can be generated with DaxLib.SVG.Transforms)
/// @returns {string} <text> element
function 'DaxLib.SVG.Element.Txt' =
		(
			x: STRING,
			y: STRING,
			txt: STRING,
			dx: STRING,
			dy: STRING,
			attributes: STRING,
			transforms: STRING
		) =>

			"<text" &
			" x='" & x & "'" &
			" y='" & y & "'" &
			IF(NOT ISBLANK( dx ), " dx='" & dx & "'" ) & 
			IF(NOT ISBLANK( dy ), " dy='" & dy & "'" ) &
			IF( NOT ISBLANK( attributes ), " " & attributes & " " ) &
			IF( NOT ISBLANK( transforms ), " transform='" & transforms & "'" ) &
			">" & txt & 
			"</text>"

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Create a pill SVG compound (rounded rectangle with text centered inside)
/// @param {int} x – The x position of compound
/// @param {int} y – The y position of compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {string} txt – The text to display
/// @param {string} color – The hex color of the pill, e.g., "#01B8AA80"
/// @returns {string} A pill-shaped SVG element with rounded corners and centered text
function 'DaxLib.SVG.Compound.Pill' = 
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			txt: STRING,
			color: STRING
		) =>

		// Apply padding to dimensions
		VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
		VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
		VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
		VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

		VAR _Pill = 
			DaxLib.SVG.Element.Rect(
				_X,                	// x
				_Y,                	// y
				_Width * 0.98,      // width
				_Height * 0.92,     // height
				10,               	// rx
				10,               	// ry
				DaxLib.SVG.Attr.Shapes(
					color,			// fill
					0.2,			// fillOpacity
					BLANK(),		// fillRule
					color,			// stroke
					1,				// strokeWidth
					BLANK(),		// strokeOpacity
					BLANK()			// opacity
				),         			// attributes
				BLANK()           	// transforms
			)

		VAR _TextElement = 
			DaxLib.SVG.Element.Txt(
				_X + (_Width * 0.50),      // x
				_Y + (_Height * 0.58),     // y
				txt,              	// txt
				0,                	// dx
				0,                	// dy
				DaxLib.SVG.Attr.Shapes(
					color,			// fill
					BLANK(),		// fillOpacity
					BLANK(),		// fillRule
					BLANK(),		// stroke
					BLANK(),		// strokeWidth
					BLANK(),		// strokeOpacity
					BLANK()			// opacity
				) &
				DaxLib.SVG.Attr.Txt(
					"Segoe UI",		// fontFamily
					12,				// fontSize
					BLANK(),		// fontWeight
					BLANK(),		// fontStyle
					"middle",		// textAnchor
					"middle",		// baseline
					BLANK(),		// textDecoration
					BLANK(),		// letterSpacing
					BLANK()			// wordSpacing
				),         			// attributes
				BLANK()				// transforms
			)

		VAR _CombinedElements = 
			_Pill & 
			_TextElement

		RETURN
		
			IF( NOT ISBLANK( txt ), _CombinedElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__


/// Creates a Bar compound SVG Visual
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {anyref} axisRef – The column that the measure will be evaluated against
/// @param {numeric} measureRef – The measure to evaluate
/// @param {string} barColor – The hex color of the bars, e.g., "#01B8AA"
/// @param {string} orientation – Optional: "Vertical" (default) or "Horizontal"
/// @param {boolean} showAxis – Optional: show axes when TRUE, defaults to FALSE
/// @param {int} axisFontSize – Optional: axis label font size, defaults to 10
/// @returns {string} SVG markup string.
function 'DaxLib.SVG.Compound.Bar' = 
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			barColor: STRING,
			orientation: STRING,
			showAxis: BOOLEAN,
			axisFontSize: INT64
		) =>

			// Apply padding to dimensions
			VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _Orientation = IF( orientation = "Horizontal", "Horizontal", "Vertical" )
			VAR _ShowAxis = IF( ISBLANK( showAxis ), FALSE(), showAxis )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
		
			VAR _Data = DaxLib.SVG.Data.AxisMeasure( axisRef, measureRef, "Auto" )
			VAR _RawYMin = MINX( _Data, [@Value] )
			VAR _RawYMax = MAXX( _Data, [@Value] )
			VAR _Range = DaxLib.SVG.Data.Range( _RawYMin, _RawYMax, TRUE() )
		
			// Define axis scales		
			VAR _XMin = 	MINX( _Data, [@AxisIndex] )
			VAR _XMax = 	MAXX( _Data, [@AxisIndex] )
			VAR _YMin = 	MINX( _Range, [@Baseline] )
			VAR _YMax = 	MAXX( _Range, [@Max] )

			VAR _YAxisMinForLabels = IF( _Orientation = "Horizontal", _XMin, _YMin )
			VAR _YAxisMaxForLabels = IF( _Orientation = "Horizontal", _XMax, _YMax )
			VAR _MaxTickLabelWidth = DaxLib.SVG.Axis.MaxTickLabelWidth( _YAxisMinForLabels, _YAxisMaxForLabels, 4, _AxisFontSize, 0.56 )
			VAR _Layout = DaxLib.SVG.Axis.Layout( _X, _Y, _Width, _Height, _ShowAxis, _AxisFontSize, _MaxTickLabelWidth )
			VAR _PlotX = MINX( _Layout, [@PlotX] )
			VAR _PlotY = MINX( _Layout, [@PlotY] )
			VAR _PlotWidth = MINX( _Layout, [@PlotWidth] )
			VAR _PlotHeight = MINX( _Layout, [@PlotHeight] )
		
			VAR _CountBars = COUNTROWS( _Data )
			VAR _BarThickness =
				DIVIDE(
					IF( _Orientation = "Horizontal", _PlotHeight, _PlotWidth ),
					_CountBars
				)

			VAR _Baseline = DaxLib.SVG.Axis.Baseline( _Orientation, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
			VAR _BaseX = MINX( _Baseline, [@BaseX] )
			VAR _BaseY = MINX( _Baseline, [@BaseY] )
		
		//Bars
		VAR _Bars = 
			CONCATENATEX(
				_Data,
				IF( 
					NOT ISBLANK( [@Value] ), 
					VAR _Point = DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
					VAR _PointX = MINX( _Point, [@X] )
					VAR _PointY = MINX( _Point, [@Y] )

					RETURN
						DaxLib.SVG.Element.Rect(
							IF( _Orientation = "Horizontal", MIN( _BaseX, _PointX ), _PointX ),
							IF( _Orientation = "Horizontal", _PointY, MIN( _BaseY, _PointY ) ),
							IF( _Orientation = "Horizontal", ABS( _PointX - _BaseX ), _BarThickness ),
							IF( _Orientation = "Horizontal", _BarThickness, ABS( _BaseY - _PointY ) ),
							0,
							0,
							DaxLib.SVG.Attr.Shapes(
								IF( NOT ISBLANK( barColor ), barColor, "#01B8AA" ),
								BLANK(),
								BLANK(),
								BLANK(),
								1,
								BLANK(),
								BLANK()
							),
							BLANK()
						)
				),
				" ",
				[@AxisIndex],
				ASC
			)

			VAR _XAxisMin = IF( _Orientation = "Horizontal", _YMin, _XMin )
			VAR _XAxisMax = IF( _Orientation = "Horizontal", _YMax, _XMax )
			VAR _YAxisMin = IF( _Orientation = "Horizontal", _XMin, _YMin )
			VAR _YAxisMax = IF( _Orientation = "Horizontal", _XMax, _YMax )
			VAR _AxisElements = DaxLib.SVG.Axis.Render( _PlotX, _PlotY, _PlotWidth, _PlotHeight, _XAxisMin, _XAxisMax, _YAxisMin, _YAxisMax, _ShowAxis, _AxisFontSize )
            
        RETURN
				
				IF( NOT ISEMPTY( _Data ) && _PlotWidth > 0 && _PlotHeight > 0, _Bars & _AxisElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Line compound SVG Visual for a numeric axis
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {anyref} axisRef – The column that the measure will be evaluated against
/// @param {numeric} measureRef – The measure to evaluate
/// @param {string} lineColor – The hex color of the line, e.g., "#01B8AA"
/// @param {string} orientation – Optional: "Vertical" (default) or "Horizontal"
/// @param {boolean} showAxis – Optional: show axes when TRUE, defaults to FALSE
/// @param {int} axisFontSize – Optional: axis label font size, defaults to 10
/// @returns {string} An SVG line chart element that visualizes the measure across the specified axis.
function 'DaxLib.SVG.Compound.Line' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			lineColor: STRING,
			orientation: STRING,
			showAxis: BOOLEAN,
			axisFontSize: INT64
		) =>

			// Apply padding to dimensions
			VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _Orientation = IF( orientation = "Horizontal", "Horizontal", "Vertical" )
			VAR _ShowAxis = IF( ISBLANK( showAxis ), FALSE(), showAxis )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
	
			VAR _Data = DaxLib.SVG.Data.AxisMeasure( axisRef, measureRef, "Auto" )
			VAR _RawYMin = MINX( _Data, [@Value] )
			VAR _RawYMax = MAXX( _Data, [@Value] )
			VAR _Range = DaxLib.SVG.Data.Range( _RawYMin, _RawYMax, TRUE() )

			// Define axis scales		
			VAR _XMin = 	MINX( _Data, [@AxisIndex] )
			VAR _XMax = 	MAXX( _Data, [@AxisIndex] )
			VAR _YMin = 	MINX( _Range, [@Baseline] )
			VAR _YMax = 	MAXX( _Range, [@Max] )

			VAR _YAxisMinForLabels = IF( _Orientation = "Horizontal", _XMin, _YMin )
			VAR _YAxisMaxForLabels = IF( _Orientation = "Horizontal", _XMax, _YMax )
			VAR _MaxTickLabelWidth = DaxLib.SVG.Axis.MaxTickLabelWidth( _YAxisMinForLabels, _YAxisMaxForLabels, 4, _AxisFontSize, 0.56 )
			VAR _Layout = DaxLib.SVG.Axis.Layout( _X, _Y, _Width, _Height, _ShowAxis, _AxisFontSize, _MaxTickLabelWidth )
			VAR _PlotX = MINX( _Layout, [@PlotX] )
			VAR _PlotY = MINX( _Layout, [@PlotY] )
			VAR _PlotWidth = MINX( _Layout, [@PlotWidth] )
			VAR _PlotHeight = MINX( _Layout, [@PlotHeight] )

			//Points
			VAR _Points = 
				CONCATENATEX(
					_Data,
					IF( 
						NOT ISBLANK( [@Value] ),
						VAR _Point = DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
						RETURN COMBINEVALUES( ",", MINX( _Point, [@X] ), MINX( _Point, [@Y] ) )
					),
					" ",
					[@AxisIndex],
					ASC
				)

			// Line Element
			VAR _LineElement =
				DaxLib.SVG.Element.Polyline(
					_Points,		// points
					DaxLib.SVG.Attr.Shapes(
						"none",		// fill
						BLANK(),	// fillOpacity
						BLANK(),	// fillRule
						IF( NOT ISBLANK( lineColor ), lineColor, "#01B8AA" ), // stroke
						1,			// stroke
						BLANK(),	// strokeOpacity
						BLANK()		// opacity
					),
					BLANK()			// transforms
				)

			// Single Point Element
			VAR _SinglePoint = DaxLib.SVG.Axis.Point( _Orientation, MAXX( _Data, [@AxisIndex] ), MAXX( _Data, [@Value] ), _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
			VAR _SinglePointElement =
				DaxLib.SVG.Element.Circle(
					MINX( _SinglePoint, [@X] ),
					MINX( _SinglePoint, [@Y] ),
					2,           	// r
					DaxLib.SVG.Attr.Shapes(
						lineColor, 	// fill
						BLANK(),    // fillOpacity
						BLANK(),    // fillRule
						BLANK(),    // stroke
						BLANK(),    // strokeWidth
						BLANK(),    // strokeOpacity
						BLANK()     // opacity
					),
					BLANK()         // transforms
				)

			// Combined elements
			VAR _CombinedElement = 
				IF(
					COUNTROWS( _Data ) = 1,
					_SinglePointElement,
					_LineElement
				)

			VAR _XAxisMin = IF( _Orientation = "Horizontal", _YMin, _XMin )
			VAR _XAxisMax = IF( _Orientation = "Horizontal", _YMax, _XMax )
			VAR _YAxisMin = IF( _Orientation = "Horizontal", _XMin, _YMin )
			VAR _YAxisMax = IF( _Orientation = "Horizontal", _XMax, _YMax )
			VAR _AxisElements = DaxLib.SVG.Axis.Render( _PlotX, _PlotY, _PlotWidth, _PlotHeight, _XAxisMin, _XAxisMax, _YAxisMin, _YAxisMax, _ShowAxis, _AxisFontSize )

			RETURN
				
				IF( NOT ISEMPTY( _Data ) && _PlotWidth > 0 && _PlotHeight > 0, _CombinedElement & _AxisElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates an Area compound SVG Visual for a numeric x-axis
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {anyref} axisRef – The column that the measure will be evaluated against
/// @param {numeric} measureRef – The measure to evaluate
/// @param {string} fillColor – The color of the area fill, e.g., "#01B8AA"
/// @param {numeric} fillOpacity – The opacity of the fill (0-1), defaults to 0.3
/// @param {string} strokeColor – The color of the stroke line
/// @param {string} orientation – Optional: "Vertical" (default) or "Horizontal"
/// @param {boolean} showAxis – Optional: show axes when TRUE, defaults to FALSE
/// @param {int} axisFontSize – Optional: axis label font size, defaults to 10
/// @returns {string} An SVG area chart element that visualizes the measure across the specified axis with filled area
function 'DaxLib.SVG.Compound.Area' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			fillColor: STRING,
			fillOpacity: NUMERIC,
			strokeColor: STRING,
			orientation: STRING,
			showAxis: BOOLEAN,
			axisFontSize: INT64
		) =>

			// Apply padding to dimensions
			VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _Orientation = IF( orientation = "Horizontal", "Horizontal", "Vertical" )
			VAR _ShowAxis = IF( ISBLANK( showAxis ), FALSE(), showAxis )
			VAR _AxisFontSize = IF( ISBLANK( axisFontSize ), 10, axisFontSize )
		
			VAR _Data = DaxLib.SVG.Data.AxisMeasure( axisRef, measureRef, "Auto" )
			VAR _RawYMin = MINX( _Data, [@Value] )
			VAR _RawYMax = MAXX( _Data, [@Value] )
			VAR _Range = DaxLib.SVG.Data.Range( _RawYMin, _RawYMax, TRUE() )
			
			VAR _XMin = 	MINX( _Data, [@AxisIndex] )
			VAR _XMax = 	MAXX( _Data, [@AxisIndex] )
			VAR _YMin = 	MINX( _Range, [@Baseline] )
			VAR _YMax = 	MAXX( _Range, [@Max] )

			VAR _YAxisMinForLabels = IF( _Orientation = "Horizontal", _XMin, _YMin )
			VAR _YAxisMaxForLabels = IF( _Orientation = "Horizontal", _XMax, _YMax )
			VAR _MaxTickLabelWidth = DaxLib.SVG.Axis.MaxTickLabelWidth( _YAxisMinForLabels, _YAxisMaxForLabels, 4, _AxisFontSize, 0.56 )
			VAR _Layout = DaxLib.SVG.Axis.Layout( _X, _Y, _Width, _Height, _ShowAxis, _AxisFontSize, _MaxTickLabelWidth )
			VAR _PlotX = MINX( _Layout, [@PlotX] )
			VAR _PlotY = MINX( _Layout, [@PlotY] )
			VAR _PlotWidth = MINX( _Layout, [@PlotWidth] )
			VAR _PlotHeight = MINX( _Layout, [@PlotHeight] )

			VAR _Baseline = DaxLib.SVG.Axis.Baseline( _Orientation, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
			VAR _BaselineX = MINX( _Baseline, [@BaseX] )
			VAR _BaselineY = MINX( _Baseline, [@BaseY] )

			VAR _DataNonBlank = FILTER( _Data, NOT ISBLANK( [@Value] ) )
			VAR _FirstDatum = TOPN( 1, _DataNonBlank, [@AxisIndex], ASC )
			VAR _LastDatum = TOPN( 1, _DataNonBlank, [@AxisIndex], DESC )

			// Get first and last X positions
			VAR _FirstX = 
				MAXX(
					_FirstDatum,
					MINX( DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight ), [@X] )
				)

			VAR _FirstY =
				MAXX(
					_FirstDatum,
					MINX( DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight ), [@Y] )
				)
			
			VAR _LastX = 
				MAXX(
					_LastDatum,
					MINX( DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight ), [@X] )
				)

			VAR _LastY =
				MAXX(
					_LastDatum,
					MINX( DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight ), [@Y] )
				)

			// Generate points for the area polygon
			// Start at baseline (bottom left), go up the data line, then back down to baseline
			VAR _PolygonPoints = 
				IF(
					_Orientation = "Horizontal",
					_BaselineX & "," & _FirstY
					& " " &
					CONCATENATEX(
						_Data,
						IF(
							NOT ISBLANK( [@Value] ),
							VAR _Point = DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
							RETURN COMBINEVALUES( ",", MINX( _Point, [@X] ), MINX( _Point, [@Y] ) )
						),
						" ",
						[@AxisIndex],
						ASC
					)
					& " " & _BaselineX & "," & _LastY,
					_FirstX & "," & _BaselineY
					& " " & 
					CONCATENATEX(
						_Data,
						IF( 
							NOT ISBLANK( [@Value] ), 
							VAR _Point = DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
							RETURN COMBINEVALUES( ",", MINX( _Point, [@X] ), MINX( _Point, [@Y] ) )
						),
						" ",
						[@AxisIndex],
						ASC
					)
					& " " & _LastX & "," & _BaselineY
				)

			// Generate points for just the top line (for optional stroke)
			VAR _TopPoints = 
				CONCATENATEX(
					_Data,
					IF( 
						NOT ISBLANK( [@Value] ), 
						VAR _Point = DaxLib.SVG.Axis.Point( _Orientation, [@AxisIndex], [@Value], _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
						RETURN COMBINEVALUES( ",", MINX( _Point, [@X] ), MINX( _Point, [@Y] ) )
					),
					" ",
					[@AxisIndex],
					ASC
				)

			// Area Element (using polygon for filled area)
			VAR _AreaElement =
				DaxLib.SVG.Element.Polygon(
					_PolygonPoints,		// points
					DaxLib.SVG.Attr.Shapes(
						fillColor, 		// fill
						IF( NOT ISBLANK( fillOpacity ), fillOpacity, 0.3 ), // fillOpacity
						BLANK(),      	// fillRule
						"none",         // stroke
						0,              // strokeWidth
						BLANK(),        // strokeOpacity
						BLANK()         // opacity
					),
					BLANK()				// transforms
				)

			// stroke line on top of the area
			VAR _StrokeElement = 
				DaxLib.SVG.Element.Polyline(
					_TopPoints,			// points
					DaxLib.SVG.Attr.Shapes(
						"none",			// fill
						BLANK(),		// fillOpacity
						BLANK(),		// fillRule
						strokeColor,	// stroke
						1,				// strokeWidth
						BLANK(),		// strokeOpacity
						BLANK()			// opacity
					),
					BLANK()				// transforms
				)
			
			// Circle if only one point
			VAR _SinglePoint = DaxLib.SVG.Axis.Point( _Orientation, MAXX( _Data, [@AxisIndex] ), MAXX( _Data, [@Value] ), _XMin, _XMax, _YMin, _YMax, _PlotX, _PlotY, _PlotWidth, _PlotHeight )
			VAR _SinglePointElement =
				DaxLib.SVG.Element.Circle(
						MINX( _SinglePoint, [@X] ),
						MINX( _SinglePoint, [@Y] ),
						2,               	// r
						DaxLib.SVG.Attr.Shapes(
							fillColor,     // fill
							BLANK(),        // fillOpacity
							BLANK(),        // fillRule
							BLANK(),        // stroke
							BLANK(),        // strokeWidth
							BLANK(),        // strokeOpacity
							BLANK()         // opacity
						),
						BLANK()             // transforms
					)

			// Combine elements
			VAR _CombinedElements = 
				IF(
					COUNTROWS( _Data ) = 1,
					_SinglePointElement,
					_AreaElement &
					_StrokeElement
				)

			VAR _XAxisMin = IF( _Orientation = "Horizontal", _YMin, _XMin )
			VAR _XAxisMax = IF( _Orientation = "Horizontal", _YMax, _XMax )
			VAR _YAxisMin = IF( _Orientation = "Horizontal", _XMin, _YMin )
			VAR _YAxisMax = IF( _Orientation = "Horizontal", _XMax, _YMax )
			VAR _AxisElements = DaxLib.SVG.Axis.Render( _PlotX, _PlotY, _PlotWidth, _PlotHeight, _XAxisMin, _XAxisMax, _YAxisMin, _YAxisMax, _ShowAxis, _AxisFontSize )

			RETURN
			
				IF( NOT ISEMPTY( _Data ) && _PlotWidth > 0 && _PlotHeight > 0, _CombinedElements & _AxisElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Jitter Plot compound SVG Visual showing values as points with x-position based on value and y-position jittered around center
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {anyref} axisRef – The column that the measure will be evaluated against
/// @param {numeric} measureRef – The measure to evaluate
/// @param {string} pointColor – The hex color of the points (e.g., "#01B8AA")
/// @param {decimal} jitterAmount – The amount of y-axis jitter as a percentage of height (0.0-1.0, defaults to 0.3)
/// @returns {string} An SVG jitter plot showing data points with horizontal positioning based on values and vertical jittering for visibility
function 'DaxLib.SVG.Compound.Jitter' = 
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			pointColor: STRING,
			jitterAmount: DOUBLE
		) =>
			
			// Apply padding to dimensions
			VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			// Check if Axis is numeric
			VAR axisSample = 	MAX( axisRef )
			VAR axisIsNumeric = ISNUMERIC( axisSample ) || ISDATETIME( axisSample )
			
			// For totals
			VAR _Data = 
				ADDCOLUMNS(
					FILTER(
						VALUES( axisRef ),
						NOT ISBLANK( measureRef )
					),
					"@AxisIndex", 	
						IF(
							axisIsNumeric,
							axisRef,
							RANK( DENSE, CALCULATETABLE( VALUES( axisRef ), ALLSELECTED() ) )
						),
					"@Value", measureRef
				)
					
			VAR _RawXMin = 	MINX( _Data, [@Value] )
			VAR _XMin = 	IF( _RawXMin > 0, 0, _RawXMin )
			VAR _XMax = 	MAXX( _Data, [@Value] )
		
			// Points
			VAR _CenterY = 		_Y + _Height * 0.5
			VAR _JitterRange = 	_Height * IF( ISBLANK( jitterAmount ), 0.3, jitterAmount )
			VAR _CircleElements = 
				CONCATENATEX(
					_Data,
					IF( 
						NOT ISBLANK( [@Value] ),
						VAR _Seed = 		ABS( [@Value] * 12345 ) + ABS( [@AxisIndex] * 67890 ) + ABS( LEN( FORMAT( [@Value], "0.000000" ) ) * 9876 )
						VAR _PseudoRandom = MOD( _Seed, 10000 ) / 10000
						VAR _JitterY = 		_CenterY + ( _PseudoRandom - 0.5 ) * _JitterRange
						VAR _ClampedY = 	MAX( _Y, MIN( _Y + _Height, _JitterY ) )
						RETURN
							DaxLib.SVG.Element.Circle(
								DaxLib.SVG.Scale.Normalize( [@Value], _XMin, _XMax, _X, _X + _Width ), // cx
								_ClampedY,          // cy
								2,         			// r
								DaxLib.SVG.Attr.Shapes(
									pointColor,   	// fill
									0.5,            // fillOpacity
									BLANK(),        // fillRule
									pointColor,   	// stroke
									1,              // strokeWidth
									0.9,            // strokeOpacity
									BLANK()         // opacity
								),
								BLANK()             // transforms
							)
					),
					" ",
					[@AxisIndex],
					ASC
				)

			RETURN
				
				IF( NOT ISEMPTY( _Data ), _CircleElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Scatter compound SVG visual using axis rows as points
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – Horizontal padding percentage (0.0-1.0)
/// @param {decimal} paddingY – Vertical padding percentage (0.0-1.0)
/// @param {anyref} axisRef – Axis grouping reference (one point per axis value)
/// @param {numeric} xMeasureRef – Measure expression for X value
/// @param {numeric} yMeasureRef – Measure expression for Y value
/// @param {string} pointColor – Optional point color
/// @param {int} pointRadius – Optional point radius
/// @returns {string} SVG circles for scatter points
function 'DaxLib.SVG.Compound.Scatter' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			xMeasureRef: NUMERIC EXPR,
			yMeasureRef: NUMERIC EXPR,
			pointColor: STRING,
			pointRadius: INT64
		) =>

			VAR _X = x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _PointColor = IF( NOT ISBLANK( pointColor ), pointColor, "#0F6CBD" )
			VAR _PointRadius = IF( ISBLANK( pointRadius ), 2, MAX( 1, pointRadius ) )

			VAR _Data =
				ADDCOLUMNS(
					VALUES( axisRef ),
					"@XValue", xMeasureRef,
					"@YValue", yMeasureRef
				)

			VAR _DataValid = FILTER( _Data, NOT ISBLANK( [@XValue] ) && NOT ISBLANK( [@YValue] ) )

			VAR _XMin = MINX( _DataValid, [@XValue] )
			VAR _XMax = MAXX( _DataValid, [@XValue] )
			VAR _YMin = MINX( _DataValid, [@YValue] )
			VAR _YMax = MAXX( _DataValid, [@YValue] )

			VAR _Points =
				CONCATENATEX(
					_DataValid,
					DaxLib.SVG.Element.Circle(
						IF( _XMax = _XMin, _X + ( _Width / 2 ), DaxLib.SVG.Scale.Normalize( [@XValue], _XMin, _XMax, _X, _X + _Width ) ),
						IF( _YMax = _YMin, _Y + ( _Height / 2 ), DaxLib.SVG.Scale.Normalize( [@YValue], _YMin, _YMax, _Y + _Height, _Y ) ),
						_PointRadius,
						DaxLib.SVG.Attr.Shapes(
							_PointColor,
							0.55,
							BLANK(),
							_PointColor,
							1,
							0.95,
							BLANK()
						),
						BLANK()
					),
					""
				)

			RETURN
				IF( NOT ISEMPTY( _DataValid ) && _Width > 0 && _Height > 0, _Points )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Histogram compound SVG visual by binning measure values
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – Horizontal padding percentage (0.0-1.0)
/// @param {decimal} paddingY – Vertical padding percentage (0.0-1.0)
/// @param {anyref} axisRef – Axis grouping reference
/// @param {numeric} measureRef – Numeric value expression to bin
/// @param {int} binCount – Number of bins
/// @param {string} barColor – Optional bar color
/// @returns {string} SVG rectangles representing histogram bins
function 'DaxLib.SVG.Compound.Histogram' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			binCount: INT64,
			barColor: STRING
		) =>

			VAR _X = x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _Color = IF( NOT ISBLANK( barColor ), barColor, "#0F6CBD" )
			VAR _Bins = IF( ISBLANK( binCount ), 10, MAX( 2, binCount ) )
			VAR _Gap = 1

			VAR _Data =
				ADDCOLUMNS(
					VALUES( axisRef ),
					"@Value", measureRef
				)

			VAR _DataValid = FILTER( _Data, NOT ISBLANK( [@Value] ) )
			VAR _MinValue = MINX( _DataValid, [@Value] )
			VAR _MaxValue = MAXX( _DataValid, [@Value] )
			VAR _Span = _MaxValue - _MinValue
			VAR _BinSize = IF( _Span = 0, 1, DIVIDE( _Span, _Bins, 1 ) )

			VAR _BinTable =
				ADDCOLUMNS(
					GENERATESERIES( 0, _Bins - 1, 1 ),
					"@BinIndex", [Value],
					"@BinStart", _MinValue + [Value] * _BinSize,
					"@BinEnd", _MinValue + ( [Value] + 1 ) * _BinSize
				)

			VAR _Counts =
				ADDCOLUMNS(
					_BinTable,
					"@Count",
						VAR _Start = [@BinStart]
						VAR _End = [@BinEnd]
						VAR _IsLastBin = [@BinIndex] = _Bins - 1
						RETURN
							COUNTROWS(
								FILTER(
									_DataValid,
									[@Value] >= _Start && IF( _IsLastBin, [@Value] <= _End, [@Value] < _End )
								)
							)
				)

			VAR _MaxCount = MAXX( _Counts, [@Count] )
			VAR _Step = DIVIDE( _Width, _Bins, 0 )
			VAR _BarWidth = MAX( 1, _Step - _Gap )

			VAR _Bars =
				CONCATENATEX(
					_Counts,
					VAR _BarHeight = IF( _MaxCount = 0, 0, DIVIDE( [@Count], _MaxCount, 0 ) * _Height )
					VAR _BarX = _X + [@BinIndex] * _Step
					VAR _BarY = _Y + _Height - _BarHeight
					RETURN
						DaxLib.SVG.Element.Rect(
							_BarX,
							_BarY,
							_BarWidth,
							_BarHeight,
							1,
							1,
							DaxLib.SVG.Attr.Shapes(
								_Color,
								0.75,
								BLANK(),
								_Color,
								1,
								BLANK(),
								BLANK()
							),
							BLANK()
						),
					""
				)

			RETURN
				IF( NOT ISEMPTY( _DataValid ) && _Width > 0 && _Height > 0, _Bars )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Bullet compound SVG visual with qualitative bands, value bar, and target marker
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – Horizontal padding percentage (0.0-1.0)
/// @param {decimal} paddingY – Vertical padding percentage (0.0-1.0)
/// @param {anyref} axisRef – Axis grouping reference
/// @param {numeric} valueRef – Actual value expression
/// @param {numeric} targetRef – Target value expression
/// @param {numeric} badThreshold – Optional lower qualitative threshold
/// @param {numeric} goodThreshold – Optional upper qualitative threshold
/// @param {string} barColor – Optional value bar color
/// @param {string} targetColor – Optional target marker color
/// @returns {string} SVG bullet chart element
function 'DaxLib.SVG.Compound.Bullet' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			valueRef: NUMERIC EXPR,
			targetRef: NUMERIC EXPR,
			badThreshold: NUMERIC,
			goodThreshold: NUMERIC,
			barColor: STRING,
			targetColor: STRING
		) =>

			VAR _X = x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _Data =
				ADDCOLUMNS(
					VALUES( axisRef ),
					"@Value", valueRef,
					"@Target", targetRef
				)

			VAR _DataValid = FILTER( _Data, NOT ISBLANK( [@Value] ) || NOT ISBLANK( [@Target] ) )

			VAR _Value = AVERAGEX( _DataValid, [@Value] )
			VAR _Target = AVERAGEX( _DataValid, [@Target] )

			VAR _RawMin =
				MIN(
					MIN( 0, MINX( _DataValid, [@Value] ) ),
					MINX( _DataValid, [@Target] )
				)

			VAR _RawMax =
				MAX(
					MAX( _Value, _Target ),
					MAXX( _DataValid, [@Value] )
				)

			VAR _BadThreshold = IF( ISBLANK( badThreshold ), _RawMax * 0.6, badThreshold )
			VAR _GoodThreshold = IF( ISBLANK( goodThreshold ), _RawMax * 0.85, goodThreshold )

			VAR _DomainMin = MIN( _RawMin, MIN( _BadThreshold, _GoodThreshold ) )
			VAR _DomainMax = MAX( _RawMax, MAX( _BadThreshold, _GoodThreshold ) )

			VAR _Baseline =
				IF(
					_DomainMin <= 0 && _DomainMax >= 0,
					0,
					_DomainMin
				)

			VAR _BandY = _Y + _Height * 0.2
			VAR _BandHeight = _Height * 0.6
			VAR _BarY = _Y + _Height * 0.32
			VAR _BarHeight = _Height * 0.36

			VAR _Band1End = MIN( _DomainMax, _BadThreshold )
			VAR _Band2End = MIN( _DomainMax, _GoodThreshold )

			VAR _Band1X = DaxLib.SVG.Scale.Normalize( _DomainMin, _DomainMin, _DomainMax, _X, _X + _Width )
			VAR _Band1W = MAX( 0, DaxLib.SVG.Scale.Normalize( _Band1End, _DomainMin, _DomainMax, _X, _X + _Width ) - _Band1X )

			VAR _Band2X = DaxLib.SVG.Scale.Normalize( _Band1End, _DomainMin, _DomainMax, _X, _X + _Width )
			VAR _Band2W = MAX( 0, DaxLib.SVG.Scale.Normalize( _Band2End, _DomainMin, _DomainMax, _X, _X + _Width ) - _Band2X )

			VAR _Band3X = DaxLib.SVG.Scale.Normalize( _Band2End, _DomainMin, _DomainMax, _X, _X + _Width )
			VAR _Band3W = MAX( 0, ( _X + _Width ) - _Band3X )

			VAR _ValueX = DaxLib.SVG.Scale.Normalize( MIN( _Value, _Baseline ), _DomainMin, _DomainMax, _X, _X + _Width )
			VAR _ValueX2 = DaxLib.SVG.Scale.Normalize( MAX( _Value, _Baseline ), _DomainMin, _DomainMax, _X, _X + _Width )
			VAR _ValueWidth = ABS( _ValueX2 - _ValueX )

			VAR _TargetX = DaxLib.SVG.Scale.Normalize( _Target, _DomainMin, _DomainMax, _X, _X + _Width )

			VAR _BarColor = IF( NOT ISBLANK( barColor ), barColor, "#0F6CBD" )
			VAR _TargetColor = IF( NOT ISBLANK( targetColor ), targetColor, "#323130" )

			VAR _Bands =
				DaxLib.SVG.Element.Rect(
					_Band1X,
					_BandY,
					_Band1W,
					_BandHeight,
					0,
					0,
					DaxLib.SVG.Attr.Shapes( "#F3F2F1", 1, BLANK(), BLANK(), BLANK(), BLANK(), BLANK() ),
					BLANK()
				)
				& DaxLib.SVG.Element.Rect(
					_Band2X,
					_BandY,
					_Band2W,
					_BandHeight,
					0,
					0,
					DaxLib.SVG.Attr.Shapes( "#E1DFDD", 1, BLANK(), BLANK(), BLANK(), BLANK(), BLANK() ),
					BLANK()
				)
				& DaxLib.SVG.Element.Rect(
					_Band3X,
					_BandY,
					_Band3W,
					_BandHeight,
					0,
					0,
					DaxLib.SVG.Attr.Shapes( "#C8C6C4", 1, BLANK(), BLANK(), BLANK(), BLANK(), BLANK() ),
					BLANK()
				)

			VAR _ValueBar =
				DaxLib.SVG.Element.Rect(
					_ValueX,
					_BarY,
					_ValueWidth,
					_BarHeight,
					1,
					1,
					DaxLib.SVG.Attr.Shapes( _BarColor, 0.9, BLANK(), _BarColor, 1, BLANK(), BLANK() ),
					BLANK()
				)

			VAR _TargetMarker =
				DaxLib.SVG.Element.Line(
					_TargetX,
					_Y + _Height * 0.12,
					_TargetX,
					_Y + _Height * 0.88,
					DaxLib.SVG.Attr.Shapes( BLANK(), BLANK(), BLANK(), _TargetColor, 2, BLANK(), BLANK() ),
					BLANK()
				)

			RETURN
				IF( NOT ISEMPTY( _DataValid ) && _Width > 0 && _Height > 0, _Bands & _ValueBar & _TargetMarker )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Lollipop compound SVG visual
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – Horizontal padding percentage (0.0-1.0)
/// @param {decimal} paddingY – Vertical padding percentage (0.0-1.0)
/// @param {anyref} axisRef – Axis grouping reference
/// @param {numeric} measureRef – Value expression
/// @param {string} lineColor – Optional stem color
/// @param {string} dotColor – Optional dot color
/// @param {string} orientation – "Vertical" (default) or "Horizontal"
/// @returns {string} SVG lollipop chart elements
function 'DaxLib.SVG.Compound.Lollipop' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			lineColor: STRING,
			dotColor: STRING,
			orientation: STRING
		) =>

			VAR _X = x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _Orientation = IF( orientation = "Horizontal", "Horizontal", "Vertical" )
			VAR _LineColor = IF( NOT ISBLANK( lineColor ), lineColor, "#0F6CBD" )
			VAR _DotColor = IF( NOT ISBLANK( dotColor ), dotColor, _LineColor )

			VAR _Data =
				ADDCOLUMNS(
					VALUES( axisRef ),
					"@AxisValue", axisRef,
					"@Value", measureRef
				)

			VAR _DataValid = FILTER( _Data, NOT ISBLANK( [@Value] ) )
			VAR _Ordered =
				ADDCOLUMNS(
					TOPN( COUNTROWS( _DataValid ), _DataValid, [@AxisValue], ASC ),
					"@Order", RANKX( _DataValid, [@AxisValue], BLANK(), ASC, DENSE )
				)

			VAR _Count = COUNTROWS( _Ordered )
			VAR _Step = DIVIDE( IF( _Orientation = "Horizontal", _Height, _Width ), _Count, 0 )

			VAR _RawMin = MINX( _Ordered, [@Value] )
			VAR _RawMax = MAXX( _Ordered, [@Value] )
			VAR _Min = IF( _RawMin > 0, 0, _RawMin )
			VAR _Max = _RawMax

			VAR _BaseX = IF( _Max = _Min, _X, DaxLib.SVG.Scale.Normalize( _Min, _Min, _Max, _X, _X + _Width ) )
			VAR _BaseY = IF( _Max = _Min, _Y + _Height, DaxLib.SVG.Scale.Normalize( _Min, _Min, _Max, _Y + _Height, _Y ) )

			VAR _Lollipops =
				CONCATENATEX(
					_Ordered,
					VAR _AxisPos = _Step * ( [@Order] - 0.5 )
					VAR _ValueX = IF( _Max = _Min, _X, DaxLib.SVG.Scale.Normalize( [@Value], _Min, _Max, _X, _X + _Width ) )
					VAR _ValueY = IF( _Max = _Min, _Y + _Height, DaxLib.SVG.Scale.Normalize( [@Value], _Min, _Max, _Y + _Height, _Y ) )
					VAR _Stem =
						DaxLib.SVG.Element.Line(
							IF( _Orientation = "Horizontal", _BaseX, _X + _AxisPos ),
							IF( _Orientation = "Horizontal", _Y + _AxisPos, _BaseY ),
							IF( _Orientation = "Horizontal", _ValueX, _X + _AxisPos ),
							IF( _Orientation = "Horizontal", _Y + _AxisPos, _ValueY ),
							DaxLib.SVG.Attr.Shapes( BLANK(), BLANK(), BLANK(), _LineColor, 1, BLANK(), BLANK() ),
							BLANK()
						)
					VAR _Dot =
						DaxLib.SVG.Element.Circle(
							IF( _Orientation = "Horizontal", _ValueX, _X + _AxisPos ),
							IF( _Orientation = "Horizontal", _Y + _AxisPos, _ValueY ),
							2,
							DaxLib.SVG.Attr.Shapes( _DotColor, 0.9, BLANK(), _DotColor, 1, BLANK(), BLANK() ),
							BLANK()
						)
					RETURN _Stem & _Dot,
					""
				)

			RETURN
				IF( NOT ISEMPTY( _Ordered ) && _Width > 0 && _Height > 0, _Lollipops )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a ProgressBar compound SVG visual
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – Horizontal padding percentage (0.0-1.0)
/// @param {decimal} paddingY – Vertical padding percentage (0.0-1.0)
/// @param {anyref} axisRef – Axis grouping reference
/// @param {numeric} valueRef – Value expression
/// @param {numeric} maxValue – Optional max value for normalization
/// @param {string} fillColor – Optional progress color
/// @param {string} trackColor – Optional track color
/// @param {string} orientation – "Horizontal" (default) or "Vertical"
/// @returns {string} SVG progress bar elements
function 'DaxLib.SVG.Compound.ProgressBar' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			valueRef: NUMERIC EXPR,
			maxValue: NUMERIC,
			fillColor: STRING,
			trackColor: STRING,
			orientation: STRING
		) =>

			VAR _X = x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			VAR _Orientation = IF( orientation = "Vertical", "Vertical", "Horizontal" )
			VAR _FillColor = IF( NOT ISBLANK( fillColor ), fillColor, "#0F6CBD" )
			VAR _TrackColor = IF( NOT ISBLANK( trackColor ), trackColor, "#E1DFDD" )

			VAR _Data = ADDCOLUMNS( VALUES( axisRef ), "@Value", valueRef )
			VAR _DataValid = FILTER( _Data, NOT ISBLANK( [@Value] ) )

			VAR _Value = AVERAGEX( _DataValid, [@Value] )
			VAR _Max = IF( ISBLANK( maxValue ), MAX( 1, _Value ), MAX( 1, maxValue ) )
			VAR _Pct = MIN( 1, MAX( 0, DIVIDE( _Value, _Max, 0 ) ) )

			VAR _Track =
				DaxLib.SVG.Element.Rect(
					_X,
					_Y,
					_Width,
					_Height,
					3,
					3,
					DaxLib.SVG.Attr.Shapes( _TrackColor, 1, BLANK(), _TrackColor, 1, BLANK(), BLANK() ),
					BLANK()
				)

			VAR _FillW = IF( _Orientation = "Horizontal", _Width * _Pct, _Width )
			VAR _FillH = IF( _Orientation = "Horizontal", _Height, _Height * _Pct )
			VAR _FillX = _X
			VAR _FillY = IF( _Orientation = "Horizontal", _Y, _Y + ( _Height - _FillH ) )

			VAR _Fill =
				DaxLib.SVG.Element.Rect(
					_FillX,
					_FillY,
					_FillW,
					_FillH,
					3,
					3,
					DaxLib.SVG.Attr.Shapes( _FillColor, 0.95, BLANK(), _FillColor, 1, BLANK(), BLANK() ),
					BLANK()
				)

			RETURN
				IF( NOT ISEMPTY( _DataValid ) && _Width > 0 && _Height > 0, _Track & _Fill )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Box Plot compound SVG Visual showing statistical distribution
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {anyref} axisRef – The column that the measure will be evaluated against
/// @param {numeric} measureRef – The measure to evaluate
/// @param {string} fillColor – Color for the box fill
/// @param {string} strokeColor – Color for lines, whiskers, and median
/// @param {boolean} showOutliers – Whether to show outlier points beyond whiskers
/// @returns {string} An SVG box plot showing statistical distribution including quartiles, median, whiskers, and optionally outliers
function 'DaxLib.SVG.Compound.Boxplot' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			fillColor: STRING,
			strokeColor: STRING,
			showOutliers: BOOLEAN
		) =>

			// Apply padding to dimensions
			VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			// Check if Axis is numeric
			VAR axisSample = 	MAX( axisRef )
			VAR axisIsNumeric = ISNUMERIC( axisSample ) || ISDATETIME( axisSample )
			
			// For totals
			VAR _Data = 
				ADDCOLUMNS(
					FILTER(
						VALUES( axisRef ),
						NOT ISBLANK( measureRef )
					),
					"@AxisIndex", 	
						IF(
							axisIsNumeric,
							axisRef,
							RANK( DENSE, CALCULATETABLE( VALUES( axisRef ), ALLSELECTED() ) )
						),
					"@Value", measureRef
				)

			VAR _XMin = 			MINX( _Data, [@Value] )
			VAR _XMax = 			MAXX( _Data, [@Value] )

			VAR _Count = 			COUNTROWS( _Data )
			VAR _Min = 				MINX( _Data, [@Value] )
			VAR _Max = 				MAXX( _Data, [@Value] )

			// Calculate quartiles using standard definitions
			VAR _Q1 = 				PERCENTILEX.INC( _Data, [@Value], 0.25 )
			VAR _Median = 			PERCENTILEX.INC( _Data, [@Value], 0.5 )
			VAR _Q3 = 				PERCENTILEX.INC( _Data, [@Value], 0.75 )

			// Calculate IQR and whisker boundaries (1.5 * IQR rule)
			VAR _IQR = 				_Q3 - _Q1
			VAR _LowerWhisker =		MAX( _Min, _Q1 - 1.5 * _IQR )
			VAR _UpperWhisker = 	MIN( _Max, _Q3 + 1.5 * _IQR )

			// Scale statistical values to SVG coordinates
			VAR _Q1X = 				DaxLib.SVG.Scale.Normalize( _Q1, _XMin, _XMax, _X, _X + _Width )
			VAR _MedianX = 			DaxLib.SVG.Scale.Normalize( _Median, _XMin, _XMax, _X, _X + _Width )
			VAR _Q3X = 				DaxLib.SVG.Scale.Normalize( _Q3, _XMin, _XMax, _X, _X + _Width )
			VAR _LowerWhiskerX = 	DaxLib.SVG.Scale.Normalize( _LowerWhisker, _XMin, _XMax, _X, _X + _Width )
			VAR _UpperWhiskerX = 	DaxLib.SVG.Scale.Normalize( _UpperWhisker, _XMin, _XMax, _X, _X + _Width )

			// Box dimensions - centered vertically with padding
			VAR _BoxHeight = 		_Height * 0.6
			VAR _BoxY = 			_Y + _Height * 0.2
			VAR _CenterY = 			_Y + _Height * 0.5

			// Create outlier points beyond whiskers if enabled
			VAR _Outliers = 
				IF(
					showOutliers,
					CONCATENATEX(
						FILTER(
							_Data,
							[@Value] < _LowerWhisker || [@Value] > _UpperWhisker
						),
						DaxLib.SVG.Element.Circle(
							DaxLib.SVG.Scale.Normalize( [@Value], _XMin, _XMax, _X, _X + _Width ), // cx
							_CenterY,          	// cy
							2,                  // radius
							DaxLib.SVG.Attr.Shapes(
								strokeColor,    // fill
								BLANK(),        // fillOpacity
								BLANK(),        // fillRule
								BLANK(),        // stroke
								BLANK(),        // strokeWidth
								BLANK(),        // strokeOpacity
								BLANK()         // opacity
							),
							BLANK()             // transforms
						),
						""
					)
				)
			
			// Lower whisker line from whisker to Q1 (horizontal)
			VAR _LowerWhiskerLine = 
				DaxLib.SVG.Element.Line(
					_LowerWhiskerX,         // x1
					_CenterY,              	// y1
					_Q1X,                   // x2
					_CenterY,              	// y2
					DaxLib.SVG.Attr.Shapes(
						BLANK(),            // fill
						BLANK(),            // fillOpacity
						BLANK(),            // fillRule
						strokeColor,        // stroke
						1,                  // strokeWidth
						BLANK(),            // strokeOpacity
						BLANK()             // opacity
					),
					BLANK()                 // transforms
				)

			// Upper whisker line from Q3 to whisker (horizontal)
			VAR _UpperWhiskerLine = 
				DaxLib.SVG.Element.Line(
					_Q3X,                   // x1
					_CenterY,             	// y1
					_UpperWhiskerX,         // x2
					_CenterY,             	// y2
					DaxLib.SVG.Attr.Shapes(
						BLANK(),            // fill
						BLANK(),            // fillOpacity
						BLANK(),            // fillRule
						strokeColor,        // stroke
						1,                  // strokeWidth
						BLANK(),            // strokeOpacity
						BLANK()             // opacity
					),
					BLANK()                 // transforms
				)

			// Lower whisker cap (vertical line)
			VAR _LowerCap = 
				DaxLib.SVG.Element.Line(
					_LowerWhiskerX,         // x1
					_BoxY,                  // y1
					_LowerWhiskerX,         // x2
					_BoxY + _BoxHeight,     // y2
					DaxLib.SVG.Attr.Shapes(
						BLANK(),            // fill
						BLANK(),            // fillOpacity
						BLANK(),            // fillRule
						strokeColor,        // stroke
						1,                  // strokeWidth
						BLANK(),            // strokeOpacity
						BLANK()             // opacity
					),
					BLANK()                 // transforms
				)

			// Upper whisker cap (vertical line)
			VAR _UpperCap = 
				DaxLib.SVG.Element.Line(
					_UpperWhiskerX,         // x1
					_BoxY,                  // y1
					_UpperWhiskerX,         // x2
					_BoxY + _BoxHeight,     // y2
					DaxLib.SVG.Attr.Shapes(
						BLANK(),            // fill
						BLANK(),            // fillOpacity
						BLANK(),            // fillRule
						strokeColor,        // stroke
						1,                  // strokeWidth
						BLANK(),            // strokeOpacity
						BLANK()             // opacity
					),
					BLANK()                 // transforms
				)

			// Main box (Q1 to Q3) - horizontal
			VAR _Box = 
				DaxLib.SVG.Element.Rect(
					_Q1X,                   // x (left of box)
					_BoxY,                  // y
					_Q3X - _Q1X,            // width (Q3 - Q1)
					_BoxHeight,             // height
					2,                      // rx
					2,                      // ry
					DaxLib.SVG.Attr.Shapes(
						fillColor,          // fill
						0.5,                // fillOpacity
						BLANK(),            // fillRule
						strokeColor,        // stroke
						1,                  // strokeWidth
						BLANK(),            // strokeOpacity
						BLANK()             // opacity
					),
					BLANK()                 // transforms
				)

			// Median line (vertical)
			VAR _MedianLine = 
				DaxLib.SVG.Element.Line(
					_MedianX,               // x1
					_BoxY,                  // y1
					_MedianX,               // x2
					_BoxY + _BoxHeight,     // y2
					DaxLib.SVG.Attr.Shapes(
						BLANK(),            // fill
						BLANK(),            // fillOpacity
						BLANK(),            // fillRule
						strokeColor,        // stroke
						2,                  // strokeWidth (thicker for median)
						BLANK(),            // strokeOpacity
						BLANK()             // opacity
					),
					BLANK()                 // transforms
				)

			// Combined elements
			VAR _CombinedElements = 
				_LowerWhiskerLine &
				_UpperWhiskerLine &
				_LowerCap &
				_UpperCap &
				_Box &
				_MedianLine &
				_Outliers

			RETURN

				IF( NOT ISEMPTY( _Data ), _CombinedElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a Violin Plot compound SVG Visual showing distribution density using Kernel Density Estimation (KDE)
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {anyref} axisRef – The column that the measure will be evaluated against
/// @param {numeric} measureRef – The measure to evaluate
/// @param {int} samples – Number of density calculation points
/// @param {numeric} bandwidth – Kernel bandwidth for smoothing
/// @param {string} color – Fill color for the violin shape
/// @returns {string} An SVG violin plot showing the probability density of data using kernel density estimation
function 'DaxLib.SVG.Compound.Violin' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			samples: INT64,
			bandwidth: NUMERIC,
			color: STRING
		) =>
		
			// Apply padding to dimensions
			VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			// Check if Axis is numeric
			VAR axisSample = 	MAX( axisRef )
			VAR axisIsNumeric = ISNUMERIC( axisSample ) || ISDATETIME( axisSample )
			
			// For totals
			VAR _Data = 
				ADDCOLUMNS(
					FILTER(
						VALUES( axisRef ),
						NOT ISBLANK( measureRef )
					),
					"@AxisIndex", 	
						IF(
							axisIsNumeric,
							axisRef,
							RANK( DENSE, CALCULATETABLE( VALUES( axisRef ), ALLSELECTED() ) )
						),
					"@Value", measureRef
				)
	
			VAR _NumValues = 		COUNTROWS( _Data )
			VAR _Min = 				MINX( _Data, [@Value] )
			VAR _Max = 				MAXX( _Data, [@Value] )
			VAR _Range = 			_Max - _Min
			VAR _RangePerSample = 	_Range / samples

			// Calculate Kernel Density Estimation using Normal distribution
			VAR _KDE = 
				ADDCOLUMNS(
					GENERATESERIES( 0, samples + 1, 1 ),
					"@InputX", _Min + _RangePerSample * [Value],
					"@KDE", 
						( 1 / _NumValues ) * 
						SUMX(
							_Data, 
							NORM.DIST( 
								_Min + _RangePerSample * [Value], 
								[@Value], 
								bandwidth, 
								FALSE 
							) 
						)
				)

			VAR _MaxKDE = 		MAXX( _KDE, [@KDE] )

			// Map KDE values to SVG coordinates using normalize function
			VAR _Points = 
				ADDCOLUMNS(
					_KDE,
					"@X", DaxLib.SVG.Scale.Normalize( [@InputX], _Min, _Max, _X, _X + _Width),
					"@Y", DaxLib.SVG.Scale.Normalize( [@KDE], 0, _MaxKDE, _Y + _Height * 0.5, _Y )
				)

			// Create control points for smooth Bézier curves
			VAR _PointsWithPrev = 
				NATURALLEFTOUTERJOIN(
					_Points,
					SELECTCOLUMNS(
						_Points,
						"Value", [Value] + 1,
						"@PrevX", [@X],
						"@PrevY", [@Y]
					)
				)

			VAR _WithControlPoints = 
				ADDCOLUMNS(
					_PointsWithPrev,
					"@CX", [@prevX] + ( ( [@x] - [@prevX] ) / 2 ),
					"@CY", [@y]
				)

		// Create the violin shape as a single closed path
		// Start at the center-left, go up the top curve, then down the bottom curve, and close
		VAR _FirstPoint = MINX( _Points, [@X] )
		VAR _LastPoint = MAXX( _Points, [@X] )
		VAR _CenterY = _Y + (_Height * 0.5)

		// Top half curve (from left to right)
		VAR _TopCurve = 
			CONCATENATEX(
				_WithControlPoints,
				IF(
					[Value] = 0,
					"M " & [@X] & " " & _CenterY,
					"S " & [@CX] & " " & [@CY] & ", " & [@X] & " " & [@Y]
				),
				" ",
				[Value],
				ASC
			)

		// Bottom half curve (from right to left, mirrored)
		VAR _BottomCurve = 
			CONCATENATEX(
				_WithControlPoints,
				VAR _MirroredY = _CenterY + (_CenterY - [@Y])
				VAR _MirroredCY = _CenterY + (_CenterY - [@CY])
				RETURN
					IF(
						[Value] = 0,
						"",
						"S " & [@CX] & " " & _MirroredCY & ", " & [@X] & " " & _MirroredY
					),
				" ",
				[Value],
				DESC
			)			// Create a single closed path for the violin shape
			VAR _ViolinPath = 
				_TopCurve & 
				" " & _BottomCurve & 
				" Z" // Close the path

			// Combined Elements
			VAR _CombinedElements = 
				DaxLib.SVG.Element.Paths(
					_ViolinPath, // d
					DaxLib.SVG.Attr.Shapes(
						color,          // fill
						0.5,          	// fillOpacity
						BLANK(),        // fillRule
						color,          // stroke
						1,              // strokeWidth
						BLANK(),        // strokeOpacity
						BLANK()         // opacity
					),
					BLANK()             // transforms
				)

			RETURN

				IF( NOT ISEMPTY( _Data ), _CombinedElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Creates a KDE-based Heatmap compound SVG Visual using Kernel Density Estimation for smooth color gradients
/// @param {int} x – The x position of the compound
/// @param {int} y – The y position of the compound
/// @param {int} width – The width of the compound
/// @param {int} height – The height of the compound
/// @param {decimal} paddingX – The horizontal padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {decimal} paddingY – The vertical padding percentage (0.0-1.0, e.g., 0.1 = 10% padding)
/// @param {anyref} axisRef – The column that the measure will be evaluated against
/// @param {numeric} measureRef – The measure to evaluate
/// @param {int} samples – Number of density calculation points (default 50)
/// @param {numeric} bandwidth – Kernel bandwidth for smoothing (default auto-calculated)
/// @param {string} color – The hex color for high density areas (e.g., "#01B8AA")
/// @returns {string} An SVG heatmap with smooth color gradients representing data density using kernel density estimation
function 'DaxLib.SVG.Compound.Heatmap' =
		(
			x: INT64,
			y: INT64,
			width: INT64,
			height: INT64,
			paddingX: DOUBLE,
			paddingY: DOUBLE,
			axisRef: ANYREF EXPR,
			measureRef: NUMERIC EXPR,
			samples: INT64,
			bandwidth: NUMERIC,
			color: STRING
		) =>
		
			// Apply padding to dimensions
			VAR _X = 			x + (width * (IF(ISBLANK(paddingX), 0, paddingX) / 2))
			VAR _Y = 			y + (height * (IF(ISBLANK(paddingY), 0, paddingY) / 2))
			VAR _Width = 		width * (1 - IF(ISBLANK(paddingX), 0, paddingX))
			VAR _Height = 		height * (1 - IF(ISBLANK(paddingY), 0, paddingY))

			// Check if Axis is numeric
			VAR axisSample = 	MAX( axisRef )
			VAR axisIsNumeric = ISNUMERIC( axisSample ) || ISDATETIME( axisSample )
			
			// For totals
			VAR _Data = 
				ADDCOLUMNS(
					FILTER(
						VALUES( axisRef ),
						NOT ISBLANK( measureRef )
					),
					"@AxisIndex", 	
						IF(
							axisIsNumeric,
							axisRef,
							RANK( DENSE, CALCULATETABLE( VALUES( axisRef ), ALLSELECTED() ) )
						),
					"@Value", measureRef
				)
			
			VAR _NumValues = 		COUNTROWS( _Data )
			VAR _Min = 				MINX( _Data, [@Value] )
			VAR _Max = 				MAXX( _Data, [@Value] )
			VAR _Range = 			_Max - _Min
			VAR _RangePerSample = 	_Range / samples

			// Calculate Kernel Density Estimation using Normal distribution
			VAR _KDE = 
				ADDCOLUMNS(
					GENERATESERIES( 0, samples, 1 ),
					"@InputX", _Min + _RangePerSample * [Value],
					"@KDE", 
						( 1 / _NumValues ) * 
						SUMX(
							_Data, 
							NORM.DIST( 
								_Min + _RangePerSample * [Value], 
								[@Value], 
								bandwidth, 
								FALSE() 
							) 
						)
				)

			VAR _MaxKDE = 		MAXX( _KDE, [@KDE] )

			// Create gradient stops from KDE points
			VAR _GradientStops = 
				CONCATENATEX(
					_KDE,
					VAR _Position = DaxLib.SVG.Scale.Normalize( [@InputX], _Min, _Max, 0, 100 )
					VAR _Intensity = IF( _MaxKDE > 0, [@KDE] / _MaxKDE, 0 )
					VAR _StopColor = 
						DaxLib.SVG.Color.Hex.Interpolate(
							"#FFFFFF",
							color,
							_Intensity
						)
					RETURN
						"<stop offset='" & _Position & "%' stop-color='" & _StopColor & "' />",
					"",
					[Value],
					ASC
				)

			// Create linear gradient definition
			VAR _GradientDef = 
				"<defs>" &
					"<linearGradient id='kde-gradient' x1='0%' y1='0%' x2='100%' y2='0%'>" &
						_GradientStops &
					"</linearGradient>" &
				"</defs>"

			// Create rectangle with gradient fill
			VAR _HeatmapRect = 
				DaxLib.SVG.Element.Rect(
					_X,                         // x
					_Y,                         // y
					_Width,                     // width
					_Height,                    // height
					0,                          // rx
					0,                          // ry
					DaxLib.SVG.Attr.Shapes(
						"url(#kde-gradient)", 	// fill
						BLANK(),                // fillOpacity
						BLANK(),                // fillRule
						BLANK(),                // stroke
						BLANK(),                // strokeWidth
						BLANK(),                // strokeOpacity
						BLANK()                 // opacity
					),
					BLANK()                     // transforms
				)
			
			// Combined elements
			VAR _CombinedElements =
				_GradientDef & 
				_HeatmapRect
					
			RETURN

				IF( NOT ISEMPTY( _Data ), _CombinedElements )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

/// Minimal wrapper for a fluent-style bar visual
/// @param {anyref} axisRefColumn – Axis reference column
/// @param {numeric} measureRefExpr – Measure expression
/// @param {string} color – Optional series color
/// @param {string} orientation – Optional orientation: "Vertical" or "Horizontal"
/// @param {boolean} showAxis – Optional axis toggle
/// @returns {string} SVG data URI with embedded bar chart
function 'DaxLib.SVG.Visual.Bar' =
		(
			axisRefColumn: ANYREF EXPR,
			measureRefExpr: NUMERIC EXPR,
			color: STRING,
			orientation: STRING,
			showAxis: BOOLEAN
		) =>

			VAR _Color = IF( NOT ISBLANK( color ), color, DaxLib.SVG.Color.Theme( "Power BI", 1 ) )
			VAR _Marks =
				DaxLib.SVG.Compound.Bar(
					0,
					0,
					120,
					48,
					0,
					0,
					axisRefColumn,
					measureRefExpr,
					_Color,
					orientation,
					showAxis,
					8
				)

			RETURN
				DaxLib.SVG.SVG( "100%", "100%", "0 0 120 48", _Marks, BLANK() )

	annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__

	annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__

